<div id="page-resoconto" class="page">
  <!-- ══ GENERA RESOCONTO ══ -->
  <div class="section">
    <div class="section-title">Creazione Resoconto per Periodo</div>
    <div class="grid2" style="margin-bottom: 12px;">
      <div><label>Data inizio</label><input type="date" id="res-inizio" oninput="aggiornaSpeseResoconto()" readonly style="font-weight:700;background:#e8eaed;cursor:not-allowed;opacity:.85"></div>
      <div><label>Data fine</label><input type="date" id="res-fine" oninput="aggiornaSpeseResoconto()"></div>
    </div>
    <div class="grid3" style="margin-bottom:12px">
      <div><label>Spese sostenute (€)</label><input type="number" id="res-spese" placeholder="0" min="0" step="0.01" readonly style="background:#e8eaed;cursor:not-allowed;opacity:.85"></div>
      <div><label>Quota da lasciare in cassa (€)</label><input type="number" id="res-cassa" placeholder="0" min="0" step="0.01"></div>
      <div>
        <label>Quota da prelevare dalla cassa (€) <span id="res-prelievo-hint" style="font-weight:400;color:var(--color-text-secondary);font-size:11px"></span></label>
        <input type="number" id="res-prelievo-cassa" placeholder="0" min="0" step="0.01" oninput="validaPrelievoResoconto(this)">
      </div>
    </div>
    <div style="margin-bottom:12px">
      <label>Nota spese <span style="font-weight:400;font-size:11px;color:var(--color-text-secondary)">(compilata automaticamente)</span></label>
