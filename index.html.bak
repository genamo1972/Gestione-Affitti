<!DOCTYPE html>
<html><head><meta charset="utf-8"><link rel="icon" href="data:image/svg+xml;base64,PHN2ZyB4bWxucz0naHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmcnIHZpZXdCb3g9JzAgMCAxMDAgMTAwJz48dGV4dCB5PScuOWVtJyBmb250LXNpemU9JzkwJz7wn4+gPC90ZXh0Pjwvc3ZnPg=="><style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:#b8bcc4;min-height:100%}
.section{background:var(--color-background-primary);border:none;border-radius:var(--border-radius-lg);padding:1.25rem;margin-bottom:1rem}
.section-title{
  font-size:15px;font-weight:700;color:#1e4f78;
  margin:-1.25rem -1.25rem 1rem -1.25rem;
  padding:10px 16px;
  background:#dceef9;
  border-left:4px solid #2a6496;
  border-bottom:1px solid #c8dff0;
  border-radius:var(--border-radius-lg) var(--border-radius-lg) 0 0;
  display:flex;align-items:center;gap:8px;
}
.section-subtitle{
  font-size:13px;font-weight:700;color:#2a6496;
  margin:1rem 0 0.6rem;padding:4px 0 4px 10px;
  border-left:3px solid #2a6496;
}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
label{font-size:13px;color:var(--color-text-secondary);display:block;margin-bottom:4px}
input,select{width:100%;font-size:14px}
select{border-radius:8px;border:1.5px solid #178a5a!important;background:#f4f5f6;color:var(--color-text-primary);font-weight:600;cursor:pointer;padding:5px 8px}
.btn{
  padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;
  border:1.5px solid var(--color-border-secondary);
  background:var(--color-background-secondary);color:var(--color-text-primary);
  box-shadow:0 1px 3px rgba(0,0,0,.08);
  transition:all 0.15s ease;
  letter-spacing:0.01em;
}
.btn:hover{background:var(--color-background-tertiary);box-shadow:0 3px 8px rgba(0,0,0,.13);transform:translateY(-1px)}
.btn:active{transform:translateY(0);box-shadow:0 1px 2px rgba(0,0,0,.1)}
/* Bottoni colorati: testo sempre bianco, hover corretto */
.btn-primary{background:linear-gradient(135deg,#178a5a,#1aad72);border-color:#178a5a;color:#fff!important}
.btn-primary:hover{background:linear-gradient(135deg,#0f6e48,#178a5a)!important;color:#fff!important}
.btn-secondary{background:linear-gradient(135deg,#e74c3c,#f1948a);border:1.5px solid #e74c3c;color:#fff!important}
.btn-secondary:hover{background:linear-gradient(135deg,#c0392b,#e74c3c)!important;border-color:#c0392b;color:#fff!important}
.btn-excel{background:linear-gradient(135deg,#1d6f42,#27a05f);border-color:#1d6f42;color:#fff!important}
.btn-excel:hover{background:linear-gradient(135deg,#155230,#1d6f42)!important;color:#fff!important}
.btn-pdf{background:linear-gradient(135deg,#c0392b,#e74c3c);border-color:#c0392b;color:#fff!important}
.btn-pdf:hover{background:linear-gradient(135deg,#96281e,#c0392b)!important;color:#fff!important}
.btn-danger{background:linear-gradient(135deg,#a32d2d,#c0392b);border-color:#a32d2d;color:#fff!important}
.btn-danger:hover{background:linear-gradient(135deg,#7d2020,#a32d2d)!important;color:#fff!important}
.metric{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:0.75rem 1rem}
.metric-label{font-size:12px;color:var(--color-text-secondary);margin-bottom:4px}
.metric-value{font-size:20px;font-weight:500;color:var(--color-text-primary)}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px;border:1px solid #b0c4d8}
th{font-size:12px;font-weight:700;text-align:left;padding:8px 10px;background:#2a6496;color:#fff;border:1px solid #1e4f78;white-space:nowrap}
td{padding:6px 10px;border:1px solid #b0c4d8;color:var(--color-text-primary);background:#f4f5f6}
tr:nth-child(even) td{background:#eaebec}
tr:hover td{background:#dceef9}
.tab-bar{
  display:flex;gap:4px;margin-bottom:1.25rem;flex-wrap:wrap;align-items:center;
  background:#1e4f78;border-radius:10px;padding:6px;
  box-shadow:0 2px 8px rgba(30,79,120,.25);
  position:sticky;top:0;z-index:100;
}
.tab{
  padding:8px 18px;border-radius:7px;font-size:13px;font-weight:700;
  cursor:pointer;border:none;
  background:transparent;color:rgba(255,255,255,.65);
  transition:all .18s ease;letter-spacing:.01em;
  display:flex;align-items:center;gap:7px;
}
.tab:hover{background:rgba(255,255,255,.12);color:#fff}
.tab.active{background:#178a5a;color:#fff;box-shadow:0 2px 6px rgba(23,138,90,.4)}
.tab-icon{font-size:17px;line-height:1}
.tab-home{margin-right:auto}
.tab-home.active{background:#e67e22;box-shadow:0 2px 6px rgba(230,126,34,.4)}
/* ── Report matrix ─────────────────────────────────────── */
#report-wrap{overflow-x:auto}
#report-wrap table{border-collapse:collapse;font-size:13px;min-width:100%}
#report-wrap th{background:#178a5a;color:#fff;padding:8px 10px;text-align:center;white-space:nowrap;border:1px solid #0e6644;font-weight:600}
#report-wrap th.col-mese{background:#e67e22;text-align:left;min-width:140px}
#report-wrap td{padding:7px 10px;text-align:center;border:1px solid #c8ddd0;vertical-align:middle}
#report-wrap td.col-mese{text-align:left;font-weight:700;background:#178a5a;color:#fff;white-space:nowrap}
#report-wrap td.ok{background:#d4edda;color:#155724;font-weight:700;font-size:15px}
#report-wrap td.ok-corrente{background:#ffc107;color:#5a3600;font-weight:700;font-size:15px}
#report-wrap td.no{background:#f8f9fa;color:#ccc}
#report-wrap td.dup{background:#fde8e8;font-size:16px;cursor:default}
@media print{
  body *{display:none!important}
  #print-report-frame,#print-report-frame *{display:block!important}
  @page{size:A4 landscape;margin:1cm}
}
.page{display:none}.page.active{display:block;background:var(--color-background-secondary);min-height:calc(100vh - 54px);padding:1.25rem}
.info-box{background:var(--color-background-info);border:0.5px solid var(--color-border-info);border-radius:var(--border-radius-md);padding:0.75rem 1rem;font-size:13px;color:var(--color-text-info);margin-bottom:1rem}
.resoconto-card{background:var(--color-background-secondary);border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-tertiary);padding:1rem;margin-bottom:0.75rem}
.resoconto-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;flex-wrap:wrap;gap:6px}
.empty{text-align:center;padding:2rem;color:var(--color-text-tertiary);font-size:14px}
.btn-group{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.mesi-tag{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:600;padding:4px 10px;border-radius:20px;background:linear-gradient(135deg,#178a5a,#1aad72);color:#fff;margin:2px;box-shadow:0 1px 3px rgba(23,138,90,.25)}
.mesi-tag .mese-x{font-size:11px;opacity:.75;margin-left:2px;transition:opacity .15s}
.mesi-tag:hover .mese-x{opacity:1}
.mese-picker{border:1.5px solid var(--color-border-tertiary);border-radius:10px;padding:10px;background:var(--color-background-secondary)}
.mese-picker-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.mese-picker-nav span{font-size:14px;font-weight:500;color:var(--color-text-primary);background:#fff9c4;border-radius:6px;padding:2px 12px;border:1px solid #f9e04b}
.mese-picker-nav button{padding:2px 10px;font-size:13px}
.mese-btn{padding:6px 4px;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;border:1.5px solid var(--color-border-tertiary);background:var(--color-background-primary);color:var(--color-text-primary);text-align:center;transition:all .15s}
.mese-btn:hover{background:var(--color-background-tertiary);border-color:#2a6496;color:#2a6496;transform:translateY(-1px)}
.mese-btn.sel{background:linear-gradient(135deg,#178a5a,#1aad72);border-color:#178a5a;color:#fff;font-weight:700;box-shadow:0 2px 6px rgba(23,138,90,.3)}
.mese-btn.suggerito{background:#fff176;border-color:#f9a825;color:#5d4037;font-weight:800;box-shadow:0 2px 6px rgba(249,168,37,.35)}
.mesi-sel-box{margin-top:8px;border:1.5px dashed #b0c4d8;border-radius:10px;padding:8px 10px;min-height:44px;background:var(--color-background-secondary);transition:border-color .2s}
.mesi-sel-box.has-items{border-style:solid;border-color:#178a5a;background:#f0faf5}
.mesi-sel-header{font-size:11px;font-weight:700;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.mesi-sel-wrap{display:flex;flex-wrap:wrap;gap:4px;align-items:center;min-height:24px}
.importo-hint{font-size:11px;color:var(--color-text-secondary);margin-top:3px}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.cassa-saldo-box{background:linear-gradient(135deg,#1a6b3a,#178a5a);color:#fff;border-radius:var(--border-radius-md);padding:1rem 1.25rem;text-align:center;margin-bottom:1rem}
.cassa-saldo-box.negativo{background:linear-gradient(135deg,#7d2020,#a32d2d)}
.cassa-saldo-label{font-size:13px;opacity:0.85;margin-bottom:4px}
.cassa-saldo-value{font-size:34px;font-weight:900;letter-spacing:-1px}
.mov-deposito{color:#178a5a;font-weight:700}
.mov-prelievo{color:#c0392b;font-weight:700}
.periodo-selector{display:flex;flex-wrap:wrap;gap:6px;align-items:center;padding:4px 0}
.periodo-btn{padding:5px 13px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;border:1.5px solid;transition:background 0.13s,color 0.13s;white-space:nowrap;line-height:1.4}
.periodo-btn-tutti{border-color:#aaa;background:var(--color-background-secondary);color:var(--color-text-secondary)}
.periodo-btn-tutti.sel,.periodo-btn-tutti:hover{background:#666;border-color:#666;color:#fff}
.periodo-btn-storico{border-color:#2a6496;background:#dceef9;color:#1e4f78}
.periodo-btn-storico.sel,.periodo-btn-storico:hover{background:#2a6496;border-color:#2a6496;color:#fff}
.periodo-btn-corrente{border-color:#178a5a;background:#e6f4ed;color:#0f6e48}
.periodo-btn-corrente.sel,.periodo-btn-corrente:hover{background:#178a5a;border-color:#178a5a;color:#fff}

/* LABEL in grassetto (sezione pagamenti e pagamenti registrati) */
#page-pagamenti label{
  font-weight: 700;
  color: var(--color-text-primary);
}

/* Barra anno con frecce — evidenziata con colore verde */
#page-pagamenti .mese-picker-nav{
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  border-radius: 10px;
  background: linear-gradient(90deg,#178a5a18,#178a5a0a);
  border: 1.5px solid #178a5a66;
  margin-bottom: 8px;
}

#page-pagamenti #picker-anno{
  font-size: 17px;
  font-weight: 900;
  color: #178a5a;
  letter-spacing: 1px;
  background:#fff9c4;border-radius:6px;padding:2px 12px;border:1px solid #f9e04b;
}

/* Storico: padding celle e stili specifici */
#storico-table td{padding:8px 10px;font-size:13px;vertical-align:middle}
#storico-table .persone-cell{font-size:11px;line-height:1.6}
#storico-table .badge-periodo{display:inline-block;font-size:11px;padding:2px 8px;border-radius:20px;background:#dceef9;color:#1e4f78;white-space:nowrap}


/* Input globale: tutti i campi testo/numero/data */
input[type=text],input[type=number],input[type=date]{
  border:1.5px solid #b0c4d8;border-radius:6px;
  background:#f4f5f6;
  padding:5px 8px;font-size:13px;
  transition:border-color 0.15s;
}
input[type=text]:focus,input[type=number]:focus,input[type=date]:focus{
  border-color:#2a6496;outline:none;
  background:#eaebec;
}
/* ── Sezione Configurazione ─────────────────────────────── */
#page-config .section-title{display:flex;align-items:center;gap:8px}
#page-config .section-title .cfg-badge{font-size:12px;font-weight:700;padding:2px 9px;border-radius:20px;background:#2a6496;color:#fff;margin-left:4px}
#cfg-eredi-title .cfg-badge{background:#178a5a!important}
/* Sfondo grigio sezioni e intestazioni tabelle in Configurazione */
#page-config .section{background:var(--color-background-secondary)}
#page-config table{background:#f4f5f6}
#page-config th{background:#d0d7de;color:var(--color-text-primary);border-color:#b0bcc8}
#erede-table th{background:#c6ddd1;border-color:#9dbfb0;color:var(--color-text-primary)}
/* Cella quota evidenziata */
.td-quota{}
/* Avatar erede */
.erede-av{width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:#fff;flex-shrink:0;margin-right:4px}

#page-resoconto label{font-weight:700;color:var(--color-text-primary)}
#page-storico label{font-weight:700;color:var(--color-text-primary)}

#btn-registra:disabled{
  opacity: 0.45;
  cursor: not-allowed;
}
/* ── Modale modifica pagamento ──────────────────────────── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9000;display:flex;align-items:center;justify-content:center;padding:16px}
.modal-box{background:rgba(255,255,255,0.15);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,0.3);border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.25);width:100%;max-width:520px;overflow:hidden}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;background:#2a6496;color:#fff}
.modal-header h3{font-size:15px;font-weight:700;margin:0}
.modal-close{background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1;padding:0 2px;opacity:.8}
.modal-close:hover{opacity:1}
.modal-body{padding:18px}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;padding:12px 18px;border-top:1px solid var(--color-border-tertiary)}
.modal-warning{background:#fff8e1;border:1.5px solid #f9a825;border-radius:8px;padding:8px 12px;font-size:12px;color:#7a5c00;margin-bottom:14px;display:flex;align-items:flex-start;gap:6px}
.btn-edit{background:linear-gradient(135deg,#2a6496,#3a84c9);border-color:#2a6496;color:#fff!important}
.btn-edit:hover{background:linear-gradient(135deg,#1e4f78,#2a6496)!important;color:#fff!important}

</style>

</head><body><div class="tab-bar">
  <div class="tab tab-home active" onclick="showPage('home')" title="Home"><span class="tab-icon">🏠</span> Home</div>
  <div class="tab" onclick="showPage('config')"><span class="tab-icon">📇</span> Anagrafiche</div>
  <div class="tab" onclick="showPage('pagamenti')"><span class="tab-icon">💶</span> Incassi</div>
  <div class="tab" onclick="showPage('spese')"><span class="tab-icon">🧾</span> Spese</div>
  <div class="tab" onclick="showPage('resoconto')"><span class="tab-icon">📊</span> Resoconti</div>
  <div class="tab" onclick="showPage('report')"><span class="tab-icon">📈</span> Report</div>
  <div class="tab" onclick="showPage('storico')"><span class="tab-icon">💰</span> Cassa</div>
  <div class="tab" onclick="showPage('strumenti')"><span class="tab-icon">🛠️</span> Strumenti</div>
<div class="tab tab-logout" onclick="eseguiLogout()" title="Logout" style="margin-left:auto;background:transparent;border-left:1px solid rgba(0,0,0,.1);color:#c0392b;font-weight:700">🚪 Logout</div>
</div>

<div id="page-home" class="page active">
  <div style="max-width:1200px;margin:2.5rem auto;text-align:center;padding:0 1rem">
    <div style="font-size:72px;margin-bottom:0.75rem">🏠</div>
    <h1 style="font-size:26px;font-weight:900;color:#1e4f78;margin-bottom:0.4rem;letter-spacing:-0.5px">Gestione Incassi Affitti</h1>
    <p style="font-size:14px;color:var(--color-text-secondary);margin-bottom:2rem;line-height:1.6;max-width:560px;margin-left:auto;margin-right:auto">
      Applicazione per la gestione dei pagamenti degli affitti, la generazione di resoconti periodici e il controllo della cassa condominiale.
    </p>
    <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:0.9rem;margin-bottom:1.5rem">
      <div onclick="showPage('config')" style="background:linear-gradient(135deg,#dbeafe,#bfdbfe);border:2px solid #93c5fd;border-radius:16px;padding:1.8rem 0.8rem;cursor:pointer;transition:box-shadow .2s,transform .15s;box-shadow:0 3px 10px rgba(59,130,246,.18);text-align:center" onmouseover="this.style.boxShadow='0 8px 22px rgba(59,130,246,.32)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='0 3px 10px rgba(59,130,246,.18)';this.style.transform='translateY(0)'">
        <div style="font-size:40px;margin-bottom:10px">📇</div>
        <div style="font-weight:800;font-size:13px;color:#1e3a8a">Anagrafiche</div>
        <div style="font-size:11px;color:#3b5bdb;margin-top:5px">Patrimonio ed eredi</div>
      </div>
      <div onclick="showPage('pagamenti')" style="background:linear-gradient(135deg,#dcfce7,#bbf7d0);border:2px solid #86efac;border-radius:16px;padding:1.8rem 0.8rem;cursor:pointer;transition:box-shadow .2s,transform .15s;box-shadow:0 3px 10px rgba(34,197,94,.18);text-align:center" onmouseover="this.style.boxShadow='0 8px 22px rgba(34,197,94,.32)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='0 3px 10px rgba(34,197,94,.18)';this.style.transform='translateY(0)'">
        <div style="font-size:40px;margin-bottom:10px">💶</div>
        <div style="font-weight:800;font-size:13px;color:#14532d">Incassi</div>
        <div style="font-size:11px;color:#166534;margin-top:5px">Registra pagamenti</div>
      </div>
      <div onclick="showPage('spese')" style="background:linear-gradient(135deg,#fff7ed,#fed7aa);border:2px solid #fdba74;border-radius:16px;padding:1.8rem 0.8rem;cursor:pointer;transition:box-shadow .2s,transform .15s;box-shadow:0 3px 10px rgba(249,115,22,.18);text-align:center" onmouseover="this.style.boxShadow='0 8px 22px rgba(249,115,22,.32)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='0 3px 10px rgba(249,115,22,.18)';this.style.transform='translateY(0)'">
        <div style="font-size:40px;margin-bottom:10px">🧾</div>
        <div style="font-weight:800;font-size:13px;color:#7c2d12">Spese</div>
        <div style="font-size:11px;color:#9a3412;margin-top:5px">Registra le spese</div>
      </div>
      <div onclick="showPage('resoconto')" style="background:linear-gradient(135deg,#fef3c7,#fde68a);border:2px solid #fcd34d;border-radius:16px;padding:1.8rem 0.8rem;cursor:pointer;transition:box-shadow .2s,transform .15s;box-shadow:0 3px 10px rgba(245,158,11,.18);text-align:center" onmouseover="this.style.boxShadow='0 8px 22px rgba(245,158,11,.32)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='0 3px 10px rgba(245,158,11,.18)';this.style.transform='translateY(0)'">
        <div style="font-size:40px;margin-bottom:10px">📊</div>
        <div style="font-weight:800;font-size:13px;color:#78350f">Resoconti</div>
        <div style="font-size:11px;color:#92400e;margin-top:5px">Chiudi periodi</div>
      </div>
      <div onclick="showPage('report')" style="background:linear-gradient(135deg,#fefce8,#fef08a);border:2px solid #facc15;border-radius:16px;padding:1.8rem 0.8rem;cursor:pointer;transition:box-shadow .2s,transform .15s;box-shadow:0 3px 10px rgba(234,179,8,.18);text-align:center" onmouseover="this.style.boxShadow='0 8px 22px rgba(234,179,8,.32)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='0 3px 10px rgba(234,179,8,.18)';this.style.transform='translateY(0)'">
        <div style="font-size:40px;margin-bottom:10px">📈</div>
        <div style="font-weight:800;font-size:13px;color:#713f12">Report</div>
        <div style="font-size:11px;color:#92400e;margin-top:5px">Matrice incassi</div>
      </div>
      <div onclick="showPage('storico')" style="background:linear-gradient(135deg,#fce7f3,#fbcfe8);border:2px solid #f9a8d4;border-radius:16px;padding:1.8rem 0.8rem;cursor:pointer;transition:box-shadow .2s,transform .15s;box-shadow:0 3px 10px rgba(236,72,153,.18);text-align:center" onmouseover="this.style.boxShadow='0 8px 22px rgba(236,72,153,.32)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='0 3px 10px rgba(236,72,153,.18)';this.style.transform='translateY(0)'">
        <div style="font-size:40px;margin-bottom:10px">💰</div>
        <div style="font-weight:800;font-size:13px;color:#831843">Cassa</div>
        <div style="font-size:11px;color:#9d174d;margin-top:5px">Movimenti e saldo</div>
      </div>
