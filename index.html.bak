<!-- ══ MODALE MODIFICA PAGAMENTO ══ -->
<div id="modal-modifica-pag" class="modal-overlay" style="display: none;" onclick="if(event.target===this)chiudiModalePagamento()">
  <div class="modal-box">
    <div class="modal-header">
      <h3 id="modal-mod-titolo">✏️ Modifica pagamento</h3>
      <button class="modal-close" onclick="chiudiModalePagamento()">✕</button>
    </div>
    <div class="modal-body">
      <div id="modal-mod-warning" class="modal-warning" style="display:none">
        ⚠️ <span>Questo pagamento appartiene a un <strong>periodo chiuso</strong>. Puoi modificare solo <strong>mesi di riferimento</strong> e <strong>note</strong> senza alterare i dati contabili.</span>
      </div>
      <div id="modal-mod-campi-base" style="display: block;">
        <div class="grid2" style="margin-bottom:10px">
          <div>
            <label>Inquilino</label>
            <input type="text" id="modal-mod-inquilino" readonly style="width:100%;background:#e8eaed;cursor:not-allowed;opacity:.85">
          </div>
          <div>
            <label>Data pagamento</label>
            <input type="date" id="modal-mod-data" style="width:100%">
          </div>
        </div>
        <div style="margin-bottom:10px">
          <label>Importo (€)</label>
          <input type="number" id="modal-mod-importo" placeholder="0,00" min="0" step="0.01" style="width:100%">
        </div>
      </div>
      <div style="margin-bottom:10px">
        <label>Mesi di riferimento</label>
        <div class="mese-picker">
          <div class="mese-picker-nav">
            <button type="button" class="btn btn-sm" onclick="modalPickerAnno(-1)">←</button>
            <span id="modal-picker-anno" style="font-size:14px;font-weight:700">2026</span>
            <button type="button" class="btn btn-sm" onclick="modalPickerAnno(+1)">→</button>
          </div>
          <div id="modal-picker-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-top:4px"></div>
        </div>
        <div class="mesi-sel-box" id="modal-mesi-sel-box" style="margin-top:8px">
          <div class="mesi-sel-header">📅 Mesi selezionati</div>
          <div class="mesi-sel-wrap" id="modal-mesi-tags"></div>
        </div>
      </div>
      <div>
        <label>Note</label>
        <input type="text" id="modal-mod-note" placeholder="Note opzionali" style="width:100%">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="chiudiModalePagamento()">Annulla</button>
      <button class="btn btn-edit" onclick="salvaModificaPagamento()">💾 Salva</button>
    </div>
  </div>
</div>

<script>
// ── Modale modifica pagamento ────────────────────────────
let _modaleId=null;
let _modaleMesiSel=[];
let _modaleAnno=new Date().getFullYear();

function apriModificaPagamento(id){
  const p=state.pagamenti.find(x=>x.id===id);
  if(!p)return;
  _modaleId=id;
  const chiuso=isPagamentoInPeriodoChiuso(id);
  _modaleMesiSel=p.mesiRif?[...p.mesiRif]:[];
  _modaleAnno=_modaleMesiSel.length?parseInt(_modaleMesiSel[_modaleMesiSel.length-1].split('-')[0]):new Date().getFullYear();

  // Warning e visibilità campi
  document.getElementById('modal-mod-warning').style.display=chiuso?'flex':'none';
  document.getElementById('modal-mod-campi-base').style.display=chiuso?'none':'block';
  document.getElementById('modal-mod-titolo').textContent=chiuso?'✏️ Modifica mesi e nota':'✏️ Modifica pagamento';

  // Popola inquilino (sola lettura)
  document.getElementById('modal-mod-inquilino').value=p.inquilino||'';

  document.getElementById('modal-mod-data').value=p.data||'';
  document.getElementById('modal-mod-importo').value=p.importo||'';
  document.getElementById('modal-mod-note').value=p.note||'';

  renderModalePicker();
  document.getElementById('modal-modifica-pag').style.display='flex';
}

function chiudiModalePagamento(){
  document.getElementById('modal-modifica-pag').style.display='none';
  _modaleId=null;
}

function modalPickerAnno(d){_modaleAnno+=d;renderModalePicker();}

function renderModalePicker(){
  const el=document.getElementById('modal-picker-anno');
  if(el)el.textContent=_modaleAnno;
  const grid=document.getElementById('modal-picker-grid');
  if(!grid)return;
  grid.innerHTML='';
  for(let m=0;m<12;m++){
    const k=mKey(_modaleAnno,m);
    const btn=document.createElement('button');
    btn.type='button';
    btn.className='mese-btn'+(_modaleMesiSel.includes(k)?' sel':'');
    btn.textContent=MESI3[m];
    btn.onclick=()=>{
      if(_modaleMesiSel.includes(k))_modaleMesiSel=_modaleMesiSel.filter(x=>x!==k);
      else _modaleMesiSel.push(k);
      _modaleMesiSel.sort();
      renderModalePicker();
    };
    grid.appendChild(btn);
  }
  // Tags mesi selezionati
  const tags=document.getElementById('modal-mesi-tags');
  const box=document.getElementById('modal-mesi-sel-box');
  if(tags){
    if(_modaleMesiSel.length){
      if(box)box.classList.add('has-items');
      tags.innerHTML=_modaleMesiSel.map(m=>{const[y,mo]=m.split('-');return`<span class="mesi-tag">${MESI3[parseInt(mo)-1]} ${y}</span>`;}).join('');
    } else {
      if(box)box.classList.remove('has-items');
      tags.innerHTML='<span style="color:var(--color-text-tertiary);font-size:12px">Nessuno — clicca sul calendario</span>';
    }
  }
}

function onModalInquilinoChange(){}  // placeholder, nessuna side-effect necessaria

function salvaModificaPagamento(){
  if(_modaleId===null)return;
  const p=state.pagamenti.find(x=>x.id===_modaleId);
  if(!p)return;
  const chiuso=isPagamentoInPeriodoChiuso(_modaleId);

  if(chiuso){
    // Periodi chiusi: solo mesi e note modificabili
    p.mesiRif=[..._modaleMesiSel];
    p.note=document.getElementById('modal-mod-note').value.trim();
    // Propaga le modifiche anche allo storico (ogni resoconto che contiene questo pagamento)
    state.storico.forEach(s=>{
      const sp=s.pags&&s.pags.find(x=>x.id===_modaleId);
      if(sp){sp.mesiRif=[..._modaleMesiSel];sp.note=p.note;}
    });
  } else {
    const inq=document.getElementById('modal-mod-inquilino').value;
    const data=document.getElementById('modal-mod-data').value;
    const importo=parseFloat(document.getElementById('modal-mod-importo').value);
    const note=document.getElementById('modal-mod-note').value.trim();
    if(!inq||!data||!importo){alert('Compila inquilino, data e importo.');return;}
    const imm=state.immobili.find(m=>m.inquilino===inq);
    p.inquilino=inq;
    p.immobile=imm?imm.nome:'';
    p.data=data;
    p.importo=importo;
    p.mesiRif=[..._modaleMesiSel];
    p.note=note;
  }
  saveState();
  chiudiModalePagamento();
  renderPagamenti();
}

/* ═══════════ SPESE ═══════════ */
function initDataSpesa(){
  const e=document.getElementById('sp-data');
  if(e&&!e.value)e.value=new Date().toISOString().split('T')[0];
}

function registraSpesa(){
  const data=document.getElementById('sp-data').value;
  const importo=parseFloat(document.getElementById('sp-importo').value)||0;
  const note=(document.getElementById('sp-note').value||'').trim();
  if(!data){alert('Inserisci la data spesa.');return;}
  if(!importo||importo<=0){alert('Inserisci un importo valido.');return;}
  state.spese.push({id:Date.now(),data,importo,note});
  saveState();
  annullaSpesa();
  renderSpese();
  aggiornaSpeseResoconto();
}

function annullaSpesa(){
  document.getElementById('sp-data').value=new Date().toISOString().split('T')[0];
  document.getElementById('sp-importo').value='';
  document.getElementById('sp-note').value='';
}

function renderSpese(){
  const filVal=(document.getElementById('fil-resoconto-spese')||{}).value||'';
  let fInizio='',fFine='';
  if(filVal){
    if(filVal.includes('>')){const p=filVal.split('>');fInizio=p[0]||'';fFine=p[1]||'';}
    else if(filVal.endsWith('|')){fInizio=filVal.slice(0,-1);fFine='';}
    else{fInizio=filVal;fFine='';}
  }
  const spese=(state.spese||[])
    .filter(s=>!filVal||((!fInizio||s.data>=fInizio)&&(!fFine||s.data<=fFine)))
    .sort((a,b)=>b.data.localeCompare(a.data));
  const tbody=document.getElementById('tbl-spese');if(!tbody)return;
  if(!spese.length){tbody.innerHTML='<tr><td colspan="4" class="empty">Nessuna spesa registrata.</td></tr>';const t=document.getElementById('tot-spese');if(t)t.textContent=fmt(0);return;}
  tbody.innerHTML=spese.map(s=>{
    const chiuso=isSpesaInPeriodoChiuso(s.data);
    const azioni=chiuso
      ? `<span title="Periodo chiuso" style="font-size:11px;color:#888;white-space:nowrap">🔒 chiuso</span>`
      : `<div style="display:flex;gap:4px;justify-content:center;align-items:center"><button class="btn btn-sm btn-edit" onclick="apriModificaSpesa(${s.id})" title="Modifica">✏️</button><button class="btn btn-sm btn-danger" onclick="rimuoviSpesa(${s.id})" title="Elimina">✕</button></div>`;
    return `<tr>
    <td style="white-space:nowrap">${fmtData(s.data)}</td>
    <td style="text-align:right;font-weight:600;color:#c0392b">${fmt(s.importo)}</td>
    <td>${s.note||'-'}</td>
    <td style="text-align:center;white-space:nowrap">${azioni}</td>
  </tr>`;
  }).join('');
  const t=document.getElementById('tot-spese');if(t)t.textContent=fmt(spese.reduce((s,x)=>s+x.importo,0));
}

function resetFiltriSpese(){
  const sel=document.getElementById('fil-resoconto-spese');if(sel)sel.value='';
  renderSpese();
}

function rimuoviSpesa(id){
  const s=(state.spese||[]).find(x=>x.id===id);
  if(s&&isSpesaInPeriodoChiuso(s.data)){alert('Impossibile eliminare: la spesa appartiene a un periodo chiuso.');return;}
  if(!confirm('Eliminare questa spesa?'))return;
  state.spese=(state.spese||[]).filter(s=>s.id!==id);
  saveState();renderSpese();aggiornaSpeseResoconto();
}

function apriModificaSpesa(id){
  const s=(state.spese||[]).find(x=>x.id===id);if(!s)return;
  if(isSpesaInPeriodoChiuso(s.data)){alert('Impossibile modificare: la spesa appartiene a un periodo chiuso.');return;}
  document.getElementById('ms-id').value=id;
  document.getElementById('ms-data').value=s.data||'';
  document.getElementById('ms-importo').value=s.importo||'';
  document.getElementById('ms-note').value=s.note||'';
  document.getElementById('modal-spesa').style.display='flex';
  document.getElementById('ms-data').focus();
}

function chiudiModaleSpesa(){document.getElementById('modal-spesa').style.display='none';}

function salvaModificaSpesa(){
  const id=parseInt(document.getElementById('ms-id').value);
  const data=document.getElementById('ms-data').value;
  const importo=parseFloat(document.getElementById('ms-importo').value)||0;
  const note=(document.getElementById('ms-note').value||'').trim();
  if(!data){alert('Inserisci la data.');return;}
  if(!importo||importo<=0){alert('Inserisci un importo valido.');return;}
  const s=(state.spese||[]).find(x=>x.id===id);if(!s)return;
  s.data=data;s.importo=importo;s.note=note;
  saveState();chiudiModaleSpesa();renderSpese();aggiornaSpeseResoconto();
}

function renderFilResocontoSpese(){
  const sel=document.getElementById('fil-resoconto-spese');if(!sel)return;
  sel.innerHTML='';
  function addOpt(parent,val,label){const o=document.createElement('option');o.value=val;o.textContent=label;parent.appendChild(o);}
  addOpt(sel,'','🔍 Tutti i periodi');
  if(!state.storico||!state.storico.length)return;
  const voci=[];
  state.storico.forEach(r=>{
    const fine=getStoricoDataFine(r);const inizio=getStoricoDataInizio(r);if(!fine)return;
    const key=(inizio||'')+'>'+fine;
    if(!voci.find(v=>v.key===key))voci.push({key,inizio,fine});
  });
  if(voci.length){
    const grp=document.createElement('optgroup');grp.label='── Periodi chiusi ──────────────';
    voci.forEach(v=>{addOpt(grp,v.key,v.inizio?'🗓  '+fmtData(v.inizio)+'  →  '+fmtData(v.fine):'🗓  Al '+fmtData(v.fine));});
    sel.appendChild(grp);
  }
  const ultimaFine=getStoricoDataFine(state.storico[0]);
  if(ultimaFine){
    const d=new Date(ultimaFine);d.setDate(d.getDate()+1);
    const dalGiorno=d.toISOString().split('T')[0];
    const grp=document.createElement('optgroup');grp.label='── Periodo corrente ────────────';
    addOpt(grp,dalGiorno+'|','▶  Dal '+fmtData(dalGiorno));
    sel.appendChild(grp);
    sel.value=dalGiorno+'|';
  }
}

function aggiornaSpeseResoconto(){
  const inizio=document.getElementById('res-inizio')?.value;
  const fine=document.getElementById('res-fine')?.value;
  if(!inizio)return;
  const speseFiltered=(state.spese||[]).filter(s=>s.data>=inizio&&(!fine||s.data<=fine)).sort((a,b)=>a.data.localeCompare(b.data));
  const totale=speseFiltered.reduce((s,x)=>s+x.importo,0);
  const eSpese=document.getElementById('res-spese');
  if(eSpese)eSpese.value=totale>0?totale.toFixed(2):'';
  const eNota=document.getElementById('res-nota-spese');
  if(eNota)eNota.value=speseFiltered.filter(s=>s.note).map(s=>`${fmtData(s.data)}: ${s.note} (${fmt(s.importo)})`).join('\n');
  // Aggiorna hint saldo cassa
  const hint=document.getElementById('res-prelievo-hint');
  if(hint)hint.textContent='(saldo disponibile: '+fmt(state.saldoCassa||0)+')';
}

function anteprimaCalcolo(){
  const inizio=document.getElementById('res-inizio').value;
  const fine=document.getElementById('res-fine').value;
  if(!inizio||!fine){alert('Inserisci le date di inizio e fine.');return;}
  if(fine<inizio){alert('La data fine deve essere successiva alla data inizio.');return;}
  const cassa=parseFloat(document.getElementById('res-cassa').value)||0;
  const prelievo=parseFloat(document.getElementById('res-prelievo-cassa').value)||0;
  const speseDelPeriodo=(state.spese||[]).filter(s=>s.data>=inizio&&s.data<=fine).sort((a,b)=>a.data.localeCompare(b.data));
  const spese=speseDelPeriodo.reduce((t,s)=>t+s.importo,0);
  const notaSpese=speseDelPeriodo.filter(s=>s.note).map(s=>`${fmtData(s.data)}: ${s.note} (${fmt(s.importo)})`).join('\n');
  const pags=state.pagamenti.filter(p=>p.data>=inizio&&p.data<=fine);
  const tot=pags.reduce((s,p)=>s+p.importo,0);
  const netto=Math.max(0,tot-spese-cassa+prelievo);
  const nPers=state.persone.length||1;
  const personeConQuota=state.persone.map(p=>({...p,quotaCalcolata:netto*parseQuota(p.quotaPatrimoniale||('1/'+nPers))}));

  const persHtml=personeConQuota.map(p=>`
    <tr>
      <td>${p.nome||'?'}</td>
      <td style="text-align:center;color:var(--color-text-secondary)">${p.quotaPatrimoniale||'—'}</td>
      <td style="text-align:right;font-weight:700;color:#178a5a">${fmt(p.quotaCalcolata)}</td>
    </tr>`).join('');

  const notaHtml=notaSpese
    ?notaSpese.split('\n').map(r=>`<li style="font-size:12px;color:var(--color-text-secondary)">${r}</li>`).join('')
    :'<li style="color:var(--color-text-tertiary);font-size:12px">Nessuna spesa nel periodo</li>';

  document.getElementById('anteprima-body').innerHTML=`
    <div style="background:#fff8e1;border:1.5px solid #fcd34d;border-radius:8px;padding:10px 14px;margin-bottom:14px;font-size:12px;color:#92400e;display:flex;gap:8px;align-items:flex-start">
      <span style="font-size:16px">⚠️</span>
      <span>Questa è solo un'<strong>anteprima</strong>. Nessun dato verrà salvato nello storico né la cassa verrà modificata.</span>
    </div>
    <table style="width:100%;border-collapse:collapse;margin-bottom:14px">
      <tr><td style="padding:5px 0;color:var(--color-text-secondary);width:55%">📅 Periodo</td>
          <td style="font-weight:700">${fmtData(inizio)} → ${fmtData(fine)}</td></tr>
      <tr><td style="padding:5px 0;color:var(--color-text-secondary)">💶 Totale incassato</td>
          <td style="font-weight:700;color:#178a5a">${fmt(tot)}</td></tr>
      <tr><td style="padding:5px 0;color:var(--color-text-secondary)">📉 Spese nel periodo</td>
          <td style="font-weight:700;color:#c0392b">${fmt(spese)}</td></tr>
      ${cassa>0?`<tr><td style="padding:5px 0;color:var(--color-text-secondary)">🏦 Depositato in cassa</td>
          <td style="font-weight:700">${fmt(cassa)}</td></tr>`:''}
      ${prelievo>0?`<tr><td style="padding:5px 0;color:var(--color-text-secondary)">📤 Prelevato dalla cassa</td>
          <td style="font-weight:700;color:#1a6b3a">${fmt(prelievo)}</td></tr>`:''}
      <tr style="border-top:2px solid var(--color-border-tertiary)">
          <td style="padding:8px 0 5px;color:var(--color-text-primary);font-weight:700">✅ Netto da dividere</td>
          <td style="font-weight:800;color:#178a5a;font-size:16px">${fmt(netto)}</td></tr>
    </table>
    <div style="font-weight:700;margin-bottom:6px">👥 Divisione (${nPers} ${nPers===1?'persona':'persone'})</div>
    <table style="width:100%;border-collapse:collapse;margin-bottom:14px">
      <thead><tr style="background:var(--color-background-secondary)">
        <th style="padding:5px 8px;text-align:left;font-size:12px">Persona</th>
        <th style="padding:5px 8px;text-align:center;font-size:12px">Quota Patrim.</th>
        <th style="padding:5px 8px;text-align:right;font-size:12px">Importo</th>
      </tr></thead>
      <tbody>${persHtml}</tbody>
    </table>
    <div style="font-weight:700;margin-bottom:4px">🧾 Dettaglio spese</div>
    <ul style="margin:0;padding-left:18px">${notaHtml}</ul>`;

  document.getElementById('modal-anteprima').style.display='flex';
}

function chiudiModaleAnteprima(){
  document.getElementById('modal-anteprima').style.display='none';
}

function validaPrelievoResoconto(inp){
  const saldo=state.saldoCassa||0;
  const val=parseFloat(inp.value)||0;
  if(val>saldo){
    inp.value=saldo.toFixed(2);
    inp.style.borderColor='#e74c3c';
    setTimeout(()=>inp.style.borderColor='',1500);
  }
}
</script>

<!-- ══ MODALE MODIFICA MOVIMENTO CASSA ══ -->
<div id="modal-mov-cassa" class="modal-overlay" style="display:none;" onclick="if(event.target===this)chiudiModaleMovimentoCassa()">
  <div class="modal-box">
    <div class="modal-header">
      <h3>✏️ Modifica movimento cassa</h3>
      <button class="modal-close" onclick="chiudiModaleMovimentoCassa()">✕</button>
    </div>
    <div class="modal-body">
      <div class="grid2" style="margin-bottom:10px">
        <div>
          <label>Tipo movimento</label>
          <select id="mc-tipo" style="width:100%">
            <option value="deposito">📥 Deposito</option>
            <option value="prelievo">📤 Prelievo</option>
          </select>
        </div>
        <div>
          <label>Data</label>
          <input type="date" id="mc-data" style="width:100%">
        </div>
      </div>
      <div style="margin-bottom:10px">
        <label>Importo (€)</label>
        <input type="number" id="mc-importo" placeholder="0,00" min="0" step="0.01" style="width:100%">
      </div>
      <div>
        <label>Nota</label>
        <input type="text" id="mc-nota" placeholder="Note opzionali" style="width:100%">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="chiudiModaleMovimentoCassa()">Annulla</button>
      <button class="btn btn-edit" onclick="salvaModificaMovimentoCassa()">💾 Salva</button>
    </div>
  </div>
</div>

<!-- ══ MODALE ANTEPRIMA CALCOLO ══ -->
<!-- ══ MODALE CONFERMA CALCOLA E CHIUDI ══ -->
<div id="modal-conferma-calcola" class="modal-overlay" style="display:none;" onclick="if(event.target===this)chiudiModaleConfermaCalcola()">
  <div class="modal-box" style="max-width:540px">
    <div class="modal-header" style="background:linear-gradient(135deg,#7a3500,#e67e22)">
      <h3>⚠️ Conferma chiusura periodo</h3>
      <button class="modal-close" onclick="chiudiModaleConfermaCalcola()">✕</button>
    </div>
    <div class="modal-body" style="font-size:14px">
      <div style="background:#fff8e1;border:1.5px solid #f9a825;border-radius:10px;padding:12px 14px;margin-bottom:16px;display:flex;gap:10px;align-items:flex-start">
        <span style="font-size:22px;line-height:1">⚠️</span>
        <div style="color:#7a5c00;font-size:13px;line-height:1.5">
          Stai per <strong>chiudere definitivamente</strong> il periodo indicato.<br>
          Questa operazione <strong>non può essere annullata</strong> e aggiornerà lo storico.
        </div>
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:0">
        <tr>
          <td style="padding:7px 10px;font-weight:700;color:#1e4f78;background:#dceef9;border:1px solid #b0c4d8;width:48%">📅 Periodo</td>
          <td id="conf-periodo" style="padding:7px 10px;background:#f4f5f6;border:1px solid #b0c4d8;font-weight:600"></td>
        </tr>
        <tr>
          <td style="padding:7px 10px;font-weight:700;color:#1e4f78;background:#dceef9;border:1px solid #b0c4d8">💶 Totale incassato</td>
          <td id="conf-tot" style="padding:7px 10px;background:#f4f5f6;border:1px solid #b0c4d8;font-weight:600;color:#178a5a"></td>
        </tr>
        <tr>
          <td style="padding:7px 10px;font-weight:700;color:#1e4f78;background:#dceef9;border:1px solid #b0c4d8">🧾 Spese sostenute</td>
          <td id="conf-spese" style="padding:7px 10px;background:#f4f5f6;border:1px solid #b0c4d8;font-weight:600;color:#c0392b"></td>
        </tr>
        <tr id="conf-row-cassa">
          <td style="padding:7px 10px;font-weight:700;color:#1e4f78;background:#dceef9;border:1px solid #b0c4d8">💰 Quota da lasciare in cassa</td>
          <td id="conf-cassa" style="padding:7px 10px;background:#f4f5f6;border:1px solid #b0c4d8;font-weight:600"></td>
        </tr>
        <tr id="conf-row-prelievo">
          <td style="padding:7px 10px;font-weight:700;color:#1e4f78;background:#dceef9;border:1px solid #b0c4d8">🏦 Prelievo dalla cassa</td>
          <td id="conf-prelievo" style="padding:7px 10px;background:#f4f5f6;border:1px solid #b0c4d8;font-weight:600"></td>
        </tr>
        <tr style="border-top:2px solid #2a6496">
          <td style="padding:9px 10px;font-weight:700;color:#fff;background:#178a5a;border:1px solid #0f6e48;font-size:14px">✅ Netto da ripartire</td>
          <td id="conf-netto" style="padding:9px 10px;background:#e6f4ed;border:1px solid #0f6e48;font-weight:800;font-size:15px;color:#0f6e48"></td>
        </tr>
        <tr>
          <td style="padding:7px 10px;font-weight:700;color:#1e4f78;background:#dceef9;border:1px solid #b0c4d8">👥 Quote per erede (<span id="conf-npersone"></span> persone)</td>
          <td id="conf-quota" style="padding:7px 10px;background:#f4f5f6;border:1px solid #b0c4d8;font-weight:700;color:#2a6496"></td>
        </tr>
      </table>
    </div>
    <div class="modal-footer" style="background:#fdf6ec;border-top:1px solid #f0d9b5">
      <button class="btn btn-secondary" onclick="chiudiModaleConfermaCalcola()">✕ Annulla</button>
      <button class="btn btn-primary" onclick="_eseguiCalcolaResoconto()" style="background:linear-gradient(135deg,#7a3500,#e67e22);border-color:#7a3500">🔒 Conferma e chiudi periodo</button>
    </div>
  </div>
</div>

<div id="modal-anteprima" class="modal-overlay" style="display:none;" onclick="if(event.target===this)chiudiModaleAnteprima()">
  <div class="modal-box" style="max-width:620px">
    <div class="modal-header" style="background:linear-gradient(135deg,#1a4a6b,#2a6496)">
      <h3>🔍 Anteprima Calcolo — nessuna modifica allo storico</h3>
      <button class="modal-close" onclick="chiudiModaleAnteprima()">✕</button>
    </div>
    <div class="modal-body" id="anteprima-body" style="font-size:14px">
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="chiudiModaleAnteprima()">✕ Chiudi</button>
    </div>
  </div>
</div>

<!-- ══ MODALE MODIFICA SPESA ══ -->
<div id="modal-spesa" class="modal-overlay" style="display:none;" onclick="if(event.target===this)chiudiModaleSpesa()">
  <div class="modal-box">
    <div class="modal-header">
      <h3>✏️ Modifica spesa</h3>
      <button class="modal-close" onclick="chiudiModaleSpesa()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="ms-id">
      <div class="grid2" style="margin-bottom:10px">
        <div>
          <label>Data spesa</label>
          <input type="date" id="ms-data" style="width:100%">
        </div>
        <div>
          <label>Importo (€)</label>
          <input type="number" id="ms-importo" placeholder="0,00" min="0" step="0.01" style="width:100%">
        </div>
      </div>
      <div>
        <label>Note</label>
        <input type="text" id="ms-note" placeholder="Descrizione spesa" style="width:100%" onkeydown="if(event.key==='Enter')salvaModificaSpesa()">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="chiudiModaleSpesa()">Annulla</button>
      <button class="btn btn-edit" onclick="salvaModificaSpesa()">💾 Salva</button>
    </div>
  </div>
</div>
</body></html>