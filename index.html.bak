<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
const MESI=['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];
const MESI3=['Gen','Feb','Mar','Apr','Mag','Giu','Lug','Ago','Set','Ott','Nov','Dic'];

let state={immobili:[],persone:[],pagamenti:[],storico:[],saldoCassa:0,movimentiCassa:[]};

// Parsa "1/3", "0.5", ecc. → numero decimale
function parseQuota(val){
  if(val===null||val===undefined||val==='')return 0;
  const s=String(val).trim();
  if(s.includes('/')){const p=s.split('/');return parseFloat(p[0])/(parseFloat(p[1])||1);}
  return parseFloat(s)||0;
}
// Converte decimale in frazione leggibile (0.333… → "1/3")
function fmtQuotaFrazione(val){
  if(val<=0)return'0';if(val>=1)return'1';
  const eps=1e-8;
  for(let d=2;d<=12;d++){const n=Math.round(val*d);if(Math.abs(n/d-val)<eps)return n+'/'+d;}
  return val.toFixed(4);
}
let pickerAnnoVal=new Date().getFullYear();
let mesiSelezionati=[];
let resPickerAnnoVal=2025;
let resMesiSelezionati=[];
let filResocontoVal='';

function loadState(){
  // Priorità 1: dati incorporati tramite scaricaHTMLConDati (variabile globale)
  if(window.__INCASSI_DATA__){
    try{state=window.__INCASSI_DATA__;window.__INCASSI_DATA__=null;saveState();return;}catch(e){}
  }
  // Priorità 2: localStorage
  try{const s=localStorage.getItem('incassi_v5');if(s)state=JSON.parse(s);}catch(e){}
  // migra da versione precedente
  try{if(!state.immobili||!state.immobili.length){const old=localStorage.getItem('incassi_v4');if(old){const o=JSON.parse(old);state=o;}}}catch(e){}
  ['immobili','persone','pagamenti','storico'].forEach(k=>{if(!state[k])state[k]=[];});
  if(!state.movimentiCassa)state.movimentiCassa=[];
  if(!state.spese)state.spese=[];
  if(typeof state.saldoCassa!=='number')state.saldoCassa=0;
  // Migra: assegna quotaPatrimoniale agli eredi che non ce l'hanno
  if(state.persone.length>0&&!state.persone[0].quotaPatrimoniale){
    const n=state.persone.length;
    state.persone.forEach(p=>{if(!p.quotaPatrimoniale)p.quotaPatrimoniale='1/'+n;});
  }
  // Migra storico: aggiunge personeConQuota ai resoconti che non ce l'hanno
  state.storico.forEach(r=>{
    if(!r.personeConQuota&&r.persone&&r.quota){
      r.personeConQuota=(r.persone||[]).map(p=>({nome:p.nome,quotaPatrimoniale:p.quotaPatrimoniale||'1/'+(r.persone.length||1),quotaCalcolata:r.quota}));
    }
  });
}
function saveState(){state.lastModified=Date.now();try{localStorage.setItem('incassi_v5',JSON.stringify(state));}catch(e){} gistAutoSync();}

// ── CLOUD SYNC (GitHub Gist) ─────────────────────────────────
const GIST_TOKEN_KEY='incassi_gist_token';
const GIST_ID_KEY='incassi_gist_id';
const GIST_FILENAME='incassi-affitti-data.json';
let _gistSyncTimer=null;

function getGistConfig(){
  return{token:localStorage.getItem(GIST_TOKEN_KEY)||'',gistId:localStorage.getItem(GIST_ID_KEY)||''};
}
function updateSyncStatus(ok,msg){
  const el=document.getElementById('cloud-sync-status');
  if(!el)return;
  if(ok){el.style.cssText='margin-bottom:12px;padding:8px 12px;border-radius:6px;font-size:13px;background:#e8f5e9;color:#1b5e20;border:1px solid #a5d6a7';el.textContent='✅ '+msg;}
  else{el.style.cssText='margin-bottom:12px;padding:8px 12px;border-radius:6px;font-size:13px;background:#ffebee;color:#b71c1c;border:1px solid #ef9a9a';el.textContent='⚠️ '+msg;}
}
function salvaConfigGist(){
  const token=document.getElementById('gist-token-inp').value.trim();
  const gistId=document.getElementById('gist-id-inp').value.trim();
  if(!token){alert('Inserisci il GitHub Personal Access Token.');return;}
  localStorage.setItem(GIST_TOKEN_KEY,token);
  if(gistId)localStorage.setItem(GIST_ID_KEY,gistId);
  updateSyncStatus(true,'Configurazione salvata. Clicca "Carica su cloud" per sincronizzare.');
}
function resettaConfigGist(){
  if(!confirm('Rimuovere la configurazione cloud?\n\nI dati locali rimarranno intatti.'))return;
  localStorage.removeItem(GIST_TOKEN_KEY);
  localStorage.removeItem(GIST_ID_KEY);
  document.getElementById('gist-token-inp').value='';
  document.getElementById('gist-id-inp').value='';
  updateSyncStatus(false,'Configurazione rimossa.');
}
function toggleTokenVisibility(){
  const inp=document.getElementById('gist-token-inp');
  const btn=document.getElementById('btn-toggle-token');
  if(inp.type==='password'){inp.type='text';btn.textContent='🙈 Nascondi';}
  else{inp.type='password';btn.textContent='👁 Mostra';}
}
async function sincronizzaOra(){
  const{token,gistId}=getGistConfig();
  if(!token){updateSyncStatus(false,'Token non configurato. Vai in Strumenti → Cloud Sync.');return;}
  updateSyncStatus(true,'⏳ Caricamento in corso…');
  const body={description:'Incassi Affitti — sincronizzato '+new Date().toLocaleString('it-IT'),public:false,files:{[GIST_FILENAME]:{content:JSON.stringify(state,null,2)}}};
  const url=gistId?`https://api.github.com/gists/${gistId}`:'https://api.github.com/gists';
  const method=gistId?'PATCH':'POST';
  try{
    const res=await fetch(url,{method,headers:{'Authorization':'token '+token,'Content-Type':'application/json','Accept':'application/vnd.github.v3+json'},body:JSON.stringify(body)});
    if(!res.ok){const e=await res.json();updateSyncStatus(false,'Errore GitHub: '+(e.message||res.status));return;}
    const data=await res.json();
    if(!gistId){
      localStorage.setItem(GIST_ID_KEY,data.id);
      const inp=document.getElementById('gist-id-inp');if(inp)inp.value=data.id;
    }
    updateSyncStatus(true,'Sincronizzato su GitHub Gist — '+new Date().toLocaleTimeString('it-IT')+(gistId?'':' — Gist creato: '+data.id));
  }catch(e){updateSyncStatus(false,'Errore di rete: '+e.message);}
}
async function scaricaDaCloud(){
  const{token,gistId}=getGistConfig();
  if(!token||!gistId){updateSyncStatus(false,'Token e ID Gist necessari per scaricare.');return;}
  if(!confirm('Scaricare i dati dal cloud?\n\nI dati attuali verranno sovrascritti con quelli presenti su GitHub Gist.\nConsiglio: esporta prima un backup JSON.'))return;
  updateSyncStatus(true,'⏳ Download in corso…');
  try{
    const res=await fetch(`https://api.github.com/gists/${gistId}`,{headers:{'Authorization':'token '+token,'Accept':'application/vnd.github.v3+json'}});
    if(!res.ok){updateSyncStatus(false,'Gist non trovato o accesso negato ('+res.status+').');return;}
    const data=await res.json();
    const file=data.files[GIST_FILENAME];
    if(!file){updateSyncStatus(false,'File "'+GIST_FILENAME+'" non trovato nel Gist.');return;}
    const content=file.truncated?(await(await fetch(file.raw_url)).text()):file.content;
    const imp=JSON.parse(content);
    ['immobili','persone','pagamenti','storico'].forEach(k=>{if(!imp[k])imp[k]=[];});
    if(!imp.movimentiCassa)imp.movimentiCassa=[];
    if(!imp.spese)imp.spese=[];
    if(typeof imp.saldoCassa!=='number')imp.saldoCassa=0;
    state=imp;
    localStorage.setItem('incassi_v5',JSON.stringify(state));
    renderImmobili();renderPersone();renderSelInquilino();
    updateSyncStatus(true,'✅ Dati scaricati da cloud — '+state.pagamenti.length+' pagamenti, '+state.immobili.length+' immobili');
    alert('✅ Dati caricati dal cloud!\n\n'+state.pagamenti.length+' pagamenti, '+state.immobili.length+' immobili');
  }catch(e){updateSyncStatus(false,'Errore: '+e.message);}
}
function gistAutoSync(){
  const{token}=getGistConfig();
  if(!token)return;
  if(_gistSyncTimer)clearTimeout(_gistSyncTimer);
  _gistSyncTimer=setTimeout(()=>sincronizzaOra(),4000);
}
function initGistUI(){
  const{token,gistId}=getGistConfig();
  const tinp=document.getElementById('gist-token-inp');
  const ginp=document.getElementById('gist-id-inp');
  if(tinp&&token)tinp.value=token;
  if(ginp&&gistId)ginp.value=gistId;
  if(token)updateSyncStatus(true,'Configurazione cloud attiva'+(gistId?' — Gist ID: '+gistId:''));
}
async function initCloudSync(){
  initGistUI();
  const{token,gistId}=getGistConfig();
  if(!token||!gistId)return;
  try{
    const res=await fetch(`https://api.github.com/gists/${gistId}`,{headers:{'Authorization':'token '+token,'Accept':'application/vnd.github.v3+json'}});
    if(!res.ok)return;
    const data=await res.json();
    const file=data.files[GIST_FILENAME];
    if(!file)return;
    const content=file.truncated?(await(await fetch(file.raw_url)).text()):file.content;
    const imp=JSON.parse(content);
    const localTs=state.lastModified||0;
    const cloudTs=imp.lastModified||0;
    if(cloudTs>localTs||(cloudTs===localTs&&JSON.stringify(imp)!==JSON.stringify(state))){
      ['immobili','persone','pagamenti','storico'].forEach(k=>{if(!imp[k])imp[k]=[];});
      if(!imp.movimentiCassa)imp.movimentiCassa=[];
      if(!imp.spese)imp.spese=[];
      if(typeof imp.saldoCassa!=='number')imp.saldoCassa=0;
      state=imp;
      localStorage.setItem('incassi_v5',JSON.stringify(state));
      renderImmobili();renderPersone();renderSelInquilino();
      updateSyncStatus(true,'☁️ Dati aggiornati dal cloud — '+new Date().toLocaleTimeString('it-IT'));
    }else{
      updateSyncStatus(true,'☁️ Dati locali aggiornati — sync cloud attivo');
    }
  }catch(e){/* silenzioso, cloud non disponibile */}
}
function fmt(n){return '€ '+Number(n).toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2});}
function fmtData(iso){if(!iso)return '-';const[y,m,d]=iso.split('-');return d+'-'+m+'-'+y;}
function mKey(y,m){return y+'-'+String(m+1).padStart(2,'0');}
function mesiLabel(arr){if(!arr||!arr.length)return '-';return arr.map(m=>{const[y,mo]=m.split('-');return MESI[parseInt(mo)-1]+' '+y;}).join(', ');}
function mesiTagsHtml(arr){if(!arr||!arr.length)return '<span style="color:var(--color-text-tertiary);font-size:12px">-</span>';return arr.map(m=>{const[y,mo]=m.split('-');return `<span class="mesi-tag">${MESI3[parseInt(mo)-1]} ${y}</span>`;}).join('');}

// Primo mese utile (successivo all'ultimo registrato per l'inquilino)
let _primoMeseUtile_=null;
function calcolaPrimoMeseUtile(inq){
  if(!inq){_primoMeseUtile_=null;return;}
  const tuttiMesi=[];
  state.pagamenti.forEach(p=>{if(p.inquilino===inq)(p.mesiRif||[]).forEach(k=>tuttiMesi.push(k));});
  if(!tuttiMesi.length){_primoMeseUtile_=null;return;}
  tuttiMesi.sort();
  const last=tuttiMesi[tuttiMesi.length-1];
  const[y,mo]=last.split('-').map(Number);
  _primoMeseUtile_=(mo===12)?((y+1)+'-01'):(y+'-'+String(mo+1).padStart(2,'0'));
}
function checkRegistraBtn(){
  const inq=document.getElementById('sel-inquilino').value;
  const importo=parseFloat(document.getElementById('inp-importo').value);
  const btn=document.getElementById('btn-registra');
  if(!btn)return;
  btn.disabled=!(inq&&importo>0);
}

// Auto-compila importo quando cambia inquilino o mesi selezionati
function aggiornaImportoAuto(){
  const inq=document.getElementById('sel-inquilino').value;
  const imm=state.immobili.find(m=>m.inquilino===inq);
  const hint=document.getElementById('importo-hint');
  if(!imm||!imm.quota){if(hint)hint.textContent='';return;}
  const nMesi=mesiSelezionati.length||1;
  const tot=imm.quota*nMesi;
  document.getElementById('inp-importo').value=tot.toFixed(2);
  if(hint){
    if(nMesi>1) hint.textContent=`Quota €${imm.quota.toLocaleString('it-IT')} × ${nMesi} mesi`;
    else hint.textContent=`Quota mensile: €${imm.quota.toLocaleString('it-IT')}`;
  }
}
function onInquilinoChange(){
  const inq=document.getElementById('sel-inquilino').value;
  const fil=document.getElementById('fil-inquilino');
  if(fil){ fil.value=inq; renderPagamenti(); }
  if(!inq){
    document.getElementById('inp-importo').value='';
    document.getElementById('inp-data').value='';
    document.getElementById('inp-note').value='';
    document.getElementById('importo-hint').textContent='';
    mesiSelezionati=[];
    _primoMeseUtile_=null;
    renderPicker();
  } else {
    calcolaPrimoMeseUtile(inq);
    // Naviga il picker all'anno del mese suggerito (se presente)
    if(_primoMeseUtile_) pickerAnnoVal=parseInt(_primoMeseUtile_.split('-')[0]);
    renderPicker();
  }
  aggiornaImportoAuto();
  checkRegistraBtn();
}

// PICKER PAGAMENTO
function pickerAnno(d){pickerAnnoVal+=d;renderPicker();}
function renderPicker(){
  const el=document.getElementById('picker-anno');if(el)el.textContent=pickerAnnoVal;
  const grid=document.getElementById('picker-grid');if(!grid)return;
  grid.innerHTML='';
  const table=document.createElement('table');
  table.style.cssText='width:100%;border-collapse:collapse';
  const COLS=3;
  for(let row=0;row<4;row++){
    const tr=document.createElement('tr');
    for(let col=0;col<COLS;col++){
      const m=row*COLS+col;
      const k=mKey(pickerAnnoVal,m);
      const td=document.createElement('td');
      td.style.cssText='padding:3px 4px;width:33.3%';
      const btn=document.createElement('button');
      btn.className='mese-btn'+(mesiSelezionati.includes(k)?' sel':(k===_primoMeseUtile_&&!mesiSelezionati.includes(k)?' suggerito':''));
      btn.type='button';
      btn.style.cssText='width:100%;font-weight:700;font-size:13px;padding:7px 4px';
      btn.textContent=MESI[m];
      btn.onclick=()=>{toggleMese(k);};
      td.appendChild(btn);
      tr.appendChild(td);
    }
    table.appendChild(tr);
  }
  grid.appendChild(table);
  renderMesiTags();
}
function toggleMese(k){
  if(mesiSelezionati.includes(k))mesiSelezionati=mesiSelezionati.filter(x=>x!==k);
  else mesiSelezionati.push(k);
  mesiSelezionati.sort();
  renderPicker();
  aggiornaImportoAuto();
  checkRegistraBtn();
}
function renderMesiTags(){
  const el=document.getElementById('mesi-sel-tags');if(!el)return;
  const box=document.getElementById('mesi-sel-box');
  if(!mesiSelezionati.length){
    el.innerHTML='<span style="color:var(--color-text-tertiary);font-size:12px">Nessuno — clicca sul calendario</span>';
    if(box)box.className='mesi-sel-box';return;
  }
  if(box)box.className='mesi-sel-box has-items';
  el.innerHTML=mesiSelezionati.map(m=>{
    const[y,mo]=m.split('-');
    return `<span class="mesi-tag" style="cursor:pointer" onclick="toggleMese('${m}')" title="Clicca per rimuovere">📅 ${MESI3[parseInt(mo)-1]} ${y}<span class="mese-x">✕</span></span>`;
  }).join('');
}

// PICKER RESOCONTO
function resPickerAnno(d){resPickerAnnoVal+=d;renderResPicker();}
function renderResPicker(){
  const el=document.getElementById('res-picker-anno');if(el)el.textContent=resPickerAnnoVal;
  const grid=document.getElementById('res-picker-grid');if(!grid)return;
  grid.innerHTML='';
  for(let m=0;m<12;m++){
    const k=mKey(resPickerAnnoVal,m);
    const btn=document.createElement('button');
    btn.className='mese-btn'+(resMesiSelezionati.includes(k)?' sel':'');
    btn.type='button';btn.textContent=MESI3[m];
    btn.onclick=()=>{toggleResMese(k);};
    grid.appendChild(btn);
  }
  renderResMesiTags();
}
function toggleResMese(k){
  if(resMesiSelezionati.includes(k))resMesiSelezionati=resMesiSelezionati.filter(x=>x!==k);
  else resMesiSelezionati.push(k);
  resMesiSelezionati.sort();
  renderResPicker();
}
function renderResMesiTags(){
  const el=document.getElementById('res-mesi-sel-tags');if(!el)return;
  const box=document.getElementById('res-mesi-sel-box');
  if(!resMesiSelezionati.length){
    el.innerHTML='<span style="color:var(--color-text-tertiary);font-size:12px">Nessuno — clicca sul calendario</span>';
    if(box)box.className='mesi-sel-box';return;
  }
  if(box)box.className='mesi-sel-box has-items';
  el.innerHTML=resMesiSelezionati.map(m=>{
    const[y,mo]=m.split('-');
    return `<span class="mesi-tag" style="cursor:pointer" onclick="toggleResMese('${m}')" title="Clicca per rimuovere">📅 ${MESI3[parseInt(mo)-1]} ${y}<span class="mese-x">✕</span></span>`;
  }).join('');
}

function showPage(p){
  document.querySelectorAll('.page').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  const tab=document.querySelector(`.tab[onclick="showPage('${p}')"]`);
  if(tab) tab.classList.add('active');
  if(p==='pagamenti'){renderSelInquilino();renderFilResoconto();renderPicker();renderPagamenti();checkRegistraBtn();}
  if(p==='resoconto'){setDefaultDate();renderStorico();aggiornaSpeseResoconto();}
  if(p==='storico')renderGestioneCassa();
  if(p==='spese'){renderFilResocontoSpese();renderSpese();initDataSpesa();}
  if(p==='report'){initReport();document.getElementById('report-wrap').innerHTML='';document.getElementById('btn-stampa-report').style.display='none';}
}

function setDefaultDate(){
  const e1=document.getElementById('res-inizio');
  const e2=document.getElementById('res-fine');
  if(e2) e2.value=new Date().toISOString().split('T')[0];
  if(e1){
    if(state.storico&&state.storico.length){
      const ultimaFine=getStoricoDataFine(state.storico[0]);
      if(ultimaFine){
        const d=new Date(ultimaFine);d.setDate(d.getDate()+1);
        const minVal=d.toISOString().split('T')[0];
        e1.value=minVal;
        e1.min=minVal;
      } else {e1.value='';e1.min='';}
    } else {e1.value='';e1.min='';}
  }
  aggiornaSpeseResoconto();
}


function renderImmobili(){
  const el=document.getElementById('immobili-list');
  const badge=document.getElementById('cfg-imm-badge');
  if(badge)badge.textContent=state.immobili.length;
  if(!state.immobili.length){
    el.innerHTML='<div class="empty" style="padding:1rem">Nessun immobile. Aggiungine uno.</div>';return;
  }
  const rows=state.immobili.map((imm,i)=>`
    <tr>
      <td>${imm.nome||'<span style="color:var(--color-text-tertiary)">—</span>'}</td>
      <td>${imm.inquilino||'<span style="color:var(--color-text-tertiary)">—</span>'}</td>
      <td class="td-quota" style="text-align:right;font-weight:700;color:#178a5a">${imm.quota?'€ '+imm.quota.toLocaleString('it-IT',{minimumFractionDigits:2}):'—'}</td>
      <td style="text-align:center;white-space:nowrap">
        <div style="display:flex;gap:4px;justify-content:center;align-items:center">
          <button class="btn btn-sm btn-edit" onclick="apriModificaImmobile(${i})" title="Modifica">✏️</button>
          <button class="btn btn-sm btn-danger" onclick="removeImmobile(${i})" title="Rimuovi">✕</button>
        </div>
      </td>
    </tr>`).join('');
  el.innerHTML=`
    <div class="table-wrap">
      <table>
        <thead><tr>
          <th>🏠 Immobile</th>
          <th>👤 Inquilino</th>
          <th style="text-align:right">💶 Affitto mensile</th>
          <th style="text-align:center;width:90px">Azioni</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
}

function renderPersone(){
  const el=document.getElementById('persone-list');
  const badge=document.getElementById('cfg-ered-badge');
  if(badge)badge.textContent=state.persone.length;
  const AVATAR_COLORS=['#178a5a','#2a6496','#8e44ad','#c0392b','#d35400','#16a085','#2980b9'];
  if(!state.persone.length){
    el.innerHTML='<div class="empty" style="padding:1rem">Nessun erede. Aggiungine uno.</div>';return;
  }
  function initials(nome){if(!nome)return '?';const p=nome.trim().split(/\s+/);return p.length>=2?(p[0][0]+p[p.length-1][0]).toUpperCase():nome[0].toUpperCase();}
  const rows=state.persone.map((p,i)=>`
    <tr>
      <td style="width:46px;text-align:center">
        <div class="erede-av" style="background:${AVATAR_COLORS[i%AVATAR_COLORS.length]}">${initials(p.nome)}</div>
      </td>
      <td>${p.nome||'<span style="color:var(--color-text-tertiary)">—</span>'}</td>
      <td style="text-align:center">${p.quotaPatrimoniale||'—'}</td>
      <td style="text-align:center;white-space:nowrap">
        <div style="display:flex;gap:4px;justify-content:center;align-items:center">
          <button class="btn btn-sm btn-edit" onclick="apriModificaPersona(${i})" title="Modifica">✏️</button>
          <button class="btn btn-sm btn-danger" onclick="removePersona(${i})" title="Rimuovi">✕</button>
        </div>
      </td>
    </tr>`).join('');
  el.innerHTML=`
    <div class="table-wrap">
      <table id="erede-table">
        <thead><tr>
          <th style="width:46px"></th>
          <th>👤 Nominativo</th>
          <th style="text-align:center">Quota Patrim.</th>
          <th style="text-align:center;width:90px">Azioni</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
}

function addImmobile(){state.immobili.push({nome:'',inquilino:'',quota:0});saveState();renderImmobili();apriModificaImmobile(state.immobili.length-1);}
function removeImmobile(i){
  const imm=state.immobili[i];if(!imm)return;
  const nPag=(state.pagamenti||[]).filter(p=>p.inquilino&&p.inquilino===imm.inquilino).length;
  const nStor=(state.storico||[]).filter(r=>(r.pags||[]).some(p=>p.inquilino===imm.inquilino)).length;
  let msg=`Rimuovere l'immobile "${imm.nome||imm.inquilino||'?'}" dall'elenco Patrimonio?`;
  if(nPag>0||nStor>0){
    msg+='\n\n⚠️ Dati storici trovati:\n';
    if(nPag>0)msg+=`  • ${nPag} pagamento/i registrato/i per questo inquilino\n`;
    if(nStor>0)msg+=`  • presente in ${nStor} resoconto/i salvato/i\n`;
    msg+='\n✅ Lo storico NON verrà alterato: tutti i dati storici resteranno invariati.';
  }
  if(!confirm(msg))return;
  state.immobili.splice(i,1);saveState();renderImmobili();renderSelInquilino();
}
function addPersona(){
  // Calcola la quota rimanente da assegnare al nuovo erede
  const totaleUsato=state.persone.reduce((s,p)=>s+parseQuota(p.quotaPatrimoniale),0);
  const rimasta=Math.max(0,1-totaleUsato);
  const nuovaQuota=rimasta>0?fmtQuotaFrazione(rimasta):'0';
  state.persone.push({nome:'',quotaPatrimoniale:nuovaQuota});
  saveState();renderPersone();apriModificaPersona(state.persone.length-1);
}
function removePersona(i){
  const p=state.persone[i];if(!p)return;
  const nRec=(state.storico||[]).filter(r=>(r.persone||[]).some(pp=>pp.nome===p.nome)).length;
  let msg=`Rimuovere l'erede "${p.nome||'?'}" dall'elenco Eredi?`;
  if(nRec>0){
    msg+=`\n\n⚠️ Questa persona compare in ${nRec} resoconto/i salvato/i nello storico.`;
    msg+='\n\n✅ Lo storico NON verrà alterato: tutti i resoconti resteranno invariati.';
  }
  if(!confirm(msg))return;
  state.persone.splice(i,1);saveState();renderPersone();
}
function salvaConfig(){saveState();alert('Anagrafiche salvate!');}

function apriModificaImmobile(i){
  const imm=state.immobili[i];if(!imm)return;
  document.getElementById('modal-imm-idx').value=i;
  document.getElementById('modal-imm-nome').value=imm.nome||'';
  document.getElementById('modal-imm-inquilino').value=imm.inquilino||'';
  document.getElementById('modal-imm-quota').value=imm.quota||'';
  document.getElementById('modal-imm').style.display='flex';
  document.getElementById('modal-imm-nome').focus();
}
function chiudiModaleImmobile(){document.getElementById('modal-imm').style.display='none';}
function salvaModificaImmobile(){
  const i=parseInt(document.getElementById('modal-imm-idx').value);
  const nome=document.getElementById('modal-imm-nome').value.trim();
  const inquilino=document.getElementById('modal-imm-inquilino').value.trim();
  const quota=parseFloat(document.getElementById('modal-imm-quota').value)||0;
  if(!nome&&!inquilino){alert('Inserisci almeno il nome immobile o l\'inquilino.');return;}
  const vecchioInquilino=state.immobili[i].inquilino||'';
  const vecchioNome=state.immobili[i].nome||'';
  state.immobili[i]={...state.immobili[i],nome,inquilino,quota};

  // Propaga cambio inquilino/nome a pagamenti
  if(vecchioInquilino!==inquilino||vecchioNome!==nome){
    state.pagamenti.forEach(p=>{
      if(p.inquilino===vecchioInquilino){
        if(vecchioInquilino!==inquilino)p.inquilino=inquilino;
        if(vecchioNome!==nome)p.immobile=nome;
      }
    });
    // Propaga nei pags dello storico
    state.storico.forEach(r=>{
      (r.pags||[]).forEach(p=>{
        if(p.inquilino===vecchioInquilino){
          if(vecchioInquilino!==inquilino)p.inquilino=inquilino;
          if(vecchioNome!==nome)p.immobile=nome;
        }
      });
    });
  }

  saveState();chiudiModaleImmobile();renderImmobili();renderSelInquilino();
  renderPagamenti();
}

function apriModificaPersona(i){
  const p=state.persone[i];if(!p)return;
  document.getElementById('modal-pers-idx').value=i;
  document.getElementById('modal-pers-nome').value=p.nome||'';
  document.getElementById('modal-pers-quota').value=p.quotaPatrimoniale||'';
  // Calcola quota già usata dagli altri eredi
  const altriTotale=state.persone.reduce((s,pp,ii)=>ii!==i?s+parseQuota(pp.quotaPatrimoniale):s,0);
  const massima=Math.max(0,1-altriTotale);
  const hint=document.getElementById('modal-pers-quota-hint');
  if(hint)hint.textContent='Quota max disponibile: '+fmtQuotaFrazione(massima)+' (somma eredi deve essere 1)';
  document.getElementById('modal-pers').style.display='flex';
  document.getElementById('modal-pers-nome').focus();
}
function chiudiModalePersona(){document.getElementById('modal-pers').style.display='none';}
function salvaModificaPersona(){
  const i=parseInt(document.getElementById('modal-pers-idx').value);
  const nome=document.getElementById('modal-pers-nome').value.trim();
  if(!nome){alert('Inserisci il nominativo.');return;}
  const quotaStr=(document.getElementById('modal-pers-quota').value||'').trim();
  const quotaVal=parseQuota(quotaStr);
  const vecchioNome=state.persone[i].nome||'';
  state.persone[i]={...state.persone[i],nome,quotaPatrimoniale:quotaStr||fmtQuotaFrazione(quotaVal)};

  // Propaga cambio nome erede nei persone dello storico
  if(vecchioNome!==nome){
    state.storico.forEach(r=>{
      (r.persone||[]).forEach(p=>{
        if(p.nome===vecchioNome)p.nome=nome;
      });
      (r.personeConQuota||[]).forEach(p=>{
        if(p.nome===vecchioNome)p.nome=nome;
      });
    });
  }

  saveState();chiudiModalePersona();renderPersone();
}

function renderSelInquilino(){
  [document.getElementById('sel-inquilino'),document.getElementById('fil-inquilino')].forEach((sel,si)=>{
    if(!sel)return;const val=sel.value;
    sel.innerHTML=si===0?'<option value="">Seleziona</option>':'<option value="">Tutti gli inquilini</option>';
    state.immobili.forEach(imm=>{if(imm.inquilino){const o=document.createElement('option');o.value=imm.inquilino;o.textContent=imm.inquilino+(imm.nome?' ('+imm.nome+')':'');sel.appendChild(o);}});
    if(val)sel.value=val;
  });
  aggiornaImportoAuto();
  checkRegistraBtn();
}

function annullaRegistrazione(){
  document.getElementById('sel-inquilino').value='';
  document.getElementById('inp-importo').value='';
  document.getElementById('inp-data').value=new Date().toISOString().split('T')[0];
  document.getElementById('inp-note').value='';
  const hint=document.getElementById('importo-hint');if(hint)hint.textContent='';
  mesiSelezionati=[];
  renderPicker();
  checkRegistraBtn();
}

function registraPagamento(){
  const inq=document.getElementById('sel-inquilino').value;
  const importo=parseFloat(document.getElementById('inp-importo').value);
  const data=document.getElementById('inp-data').value;
  const note=document.getElementById('inp-note').value;
  if(!inq||!importo||!data){alert('Compila inquilino, importo e data.');return;}
  // Verifica mesi già registrati per questo inquilino
  if(mesiSelezionati.length){
    const giàRegistrati=new Set();
    state.pagamenti.forEach(p=>{if(p.inquilino===inq)(p.mesiRif||[]).forEach(k=>giàRegistrati.add(k));});
    const duplicati=mesiSelezionati.filter(k=>giàRegistrati.has(k));
    if(duplicati.length){
      const labels=duplicati.map(k=>{const[y,mo]=k.split('-');return MESI[parseInt(mo)-1]+' '+y;});
      alert('⚠️ Registrazione bloccata!\n\nI seguenti mesi sono già registrati per '+inq+':\n\n• '+labels.join('\n• ')+'\n\nRimuovi i mesi duplicati prima di procedere.');
      return;
    }
  }
  const imm=state.immobili.find(m=>m.inquilino===inq);
  state.pagamenti.push({id:Date.now(),inquilino:inq,immobile:imm?imm.nome:'',importo,data,mesiRif:[...mesiSelezionati],note});
  saveState();
  document.getElementById('sel-inquilino').value='';
  document.getElementById('inp-importo').value='';
  document.getElementById('inp-data').value='';
  document.getElementById('inp-note').value='';
  document.getElementById('importo-hint').textContent='';
  mesiSelezionati=[];
  _primoMeseUtile_=null;
  renderPicker();
  renderPagamenti();
  checkRegistraBtn();
}

function renderPagamenti(){
  const fil=(document.getElementById('fil-inquilino')||{}).value||'';
  const filResoconto=filResocontoVal||'';
  let fInizio='',fFine='';
  if(filResoconto){
    if(filResoconto.includes('>')){const p=filResoconto.split('>');fInizio=p[0]||'';fFine=p[1]||'';}
    else if(filResoconto.endsWith('|')){fInizio=filResoconto.slice(0,-1);fFine='';}
    else{fInizio=filResoconto;fFine='';}
  }
  const pags=state.pagamenti
    .filter(p=>(!fil||p.inquilino===fil)&&
               (!filResoconto||
                ((!fInizio||p.data>=fInizio)&&(!fFine||p.data<=fFine))))
    .sort((a,b)=>b.data.localeCompare(a.data));
  const tbody=document.getElementById('tbl-pagamenti');tbody.innerHTML='';
  if(!pags.length){tbody.innerHTML='<tr><td colspan="7" class="empty">Nessun pagamento registrato.</td></tr>';}
  pags.forEach(p=>{
    const tr=document.createElement('tr');
    const chiuso=isPagamentoInPeriodoChiuso(p.id);
    const btnCancella=chiuso
      ?`<button class="btn btn-sm btn-danger" disabled title="Periodo chiuso: cancellazione non consentita" style="opacity:.45;cursor:not-allowed">X</button>`
      :`<button class="btn btn-sm btn-danger" onclick="rimuoviPagamento(${p.id})">X</button>`;
    tr.innerHTML=`<td>${fmtData(p.data)}</td><td>${mesiTagsHtml(p.mesiRif)}</td><td>${p.inquilino}</td><td>${p.immobile||'-'}</td><td>${fmt(p.importo)}</td><td>${p.note||'-'}</td><td style="text-align:center;white-space:nowrap"><div style="display:flex;gap:4px;justify-content:center;align-items:center"><button class="btn btn-sm btn-edit" onclick="apriModificaPagamento(${p.id})" title="${chiuso?'Modifica nota':'Modifica pagamento'}">✏️</button>${btnCancella}</div></td>`;
    tbody.appendChild(tr);
  });
  document.getElementById('tot-incassato').textContent=fmt(pags.reduce((s,p)=>s+p.importo,0));
}

function isPagamentoInPeriodoChiuso(id){
  if(!state.storico||!state.storico.length)return false;
  return state.storico.some(r=>(r.pags||[]).some(p=>p.id===id));
}

function isSpesaInPeriodoChiuso(data){
  if(!state.storico||!state.storico.length)return false;
  return state.storico.some(r=>{
    const ini=getStoricoDataInizio(r);const fin=getStoricoDataFine(r);
    return fin&&data<=fin&&(!ini||data>=ini);
  });
}

function rimuoviPagamento(id){
  if(isPagamentoInPeriodoChiuso(id)){alert('Impossibile eliminare: il pagamento appartiene a un periodo chiuso (resoconto già salvato).');return;}
  if(!confirm('Rimuovere questo pagamento?'))return;
  state.pagamenti=state.pagamenti.filter(p=>p.id!==id);saveState();renderPagamenti();
}

function annullaResoconto(){
  setDefaultDate(); // chiama aggiornaSpeseResoconto() → popola res-spese e res-nota-spese
  document.getElementById('res-cassa').value='';
  document.getElementById('res-prelievo-cassa').value='';
  // res-spese e res-nota-spese sono readonly: gestiti da aggiornaSpeseResoconto, non svuotare
}
function calcolaResoconto(){
  const cassa=parseFloat(document.getElementById('res-cassa').value)||0;
  const prelievo=parseFloat(document.getElementById('res-prelievo-cassa').value)||0;
  const inizio=document.getElementById('res-inizio').value;
  const fine=document.getElementById('res-fine').value;
  if(!inizio||!fine){alert('Inserisci le date di inizio e fine.');return;}
  if(fine<inizio){alert('La data fine deve essere successiva alla data inizio.');return;}
  if(state.storico&&state.storico.length){
    const ultimaFine=getStoricoDataFine(state.storico[0]);
    if(ultimaFine&&inizio<=ultimaFine){
      alert('La data inizio ('+fmtData(inizio)+') deve essere successiva all\'ultima data di fine periodo chiuso ('+fmtData(ultimaFine)+').');return;
    }
  }
  // Ricalcola spese direttamente da state.spese (fonte di verità)
  const speseDelPeriodo=(state.spese||[]).filter(s=>s.data>=inizio&&s.data<=fine).sort((a,b)=>a.data.localeCompare(b.data));
  const spese=speseDelPeriodo.reduce((t,s)=>t+s.importo,0);
  const pags=state.pagamenti.filter(p=>p.data>=inizio&&p.data<=fine);
  const tot=pags.reduce((s,p)=>s+p.importo,0);
  const netto=Math.max(0,tot-spese-cassa+prelievo);
  const nPers=state.persone.length||1;
  // Calcola quote per erede in base alla quota patrimoniale
  const personeConQuota=state.persone.map(p=>({...p,quotaCalcolata:netto*parseQuota(p.quotaPatrimoniale||('1/'+nPers))}));
  // Popola e mostra dialog di conferma
  document.getElementById('conf-periodo').textContent=fmtData(inizio)+' → '+fmtData(fine);
  document.getElementById('conf-tot').textContent=fmt(tot);
  document.getElementById('conf-spese').textContent=fmt(spese);
  document.getElementById('conf-cassa').textContent=fmt(cassa);
  document.getElementById('conf-prelievo').textContent=fmt(prelievo);
  document.getElementById('conf-netto').textContent=fmt(netto);
  document.getElementById('conf-npersone').textContent=nPers;
  document.getElementById('conf-quota').innerHTML=personeConQuota.map(p=>`<span style="display:block">${p.nome||'?'}: <strong>${fmt(p.quotaCalcolata)}</strong> (${p.quotaPatrimoniale||'—'})</span>`).join('');
  // Mostra/nascondi righe cassa e prelievo
  document.getElementById('conf-row-cassa').style.display=cassa>0?'':'none';
  document.getElementById('conf-row-prelievo').style.display=prelievo>0?'':'none';
  document.getElementById('modal-conferma-calcola').style.display='flex';
}
function chiudiModaleConfermaCalcola(){
  document.getElementById('modal-conferma-calcola').style.display='none';
}
function _eseguiCalcolaResoconto(){
  chiudiModaleConfermaCalcola();
  const cassa=parseFloat(document.getElementById('res-cassa').value)||0;
  const prelievo=parseFloat(document.getElementById('res-prelievo-cassa').value)||0;
  const inizio=document.getElementById('res-inizio').value;
  const fine=document.getElementById('res-fine').value;
  const speseDelPeriodo=(state.spese||[]).filter(s=>s.data>=inizio&&s.data<=fine).sort((a,b)=>a.data.localeCompare(b.data));
  const spese=speseDelPeriodo.reduce((t,s)=>t+s.importo,0);
  const notaSpese=speseDelPeriodo.filter(s=>s.note).map(s=>`${fmtData(s.data)}: ${s.note} (${fmt(s.importo)})`).join('\n');
  let pags=state.pagamenti.filter(p=>p.data>=inizio&&p.data<=fine).sort((a,b)=>a.data.localeCompare(b.data));
  const periodoLabel=fmtData(inizio)+' → '+fmtData(fine)+' (per data pagamento)';
  const tot=pags.reduce((s,p)=>s+p.importo,0);
  const netto=Math.max(0,tot-spese-cassa+prelievo);
  const nPers=state.persone.length||1;
  const quota=netto/nPers;
  // Calcola quote individuali in base alla quota patrimoniale
  const personeConQuota=state.persone.map(p=>({...p,quotaCalcolata:netto*parseQuota(p.quotaPatrimoniale||('1/'+nPers))}));
  const now=new Date().toISOString();
  const r={periodoLabel,dataInizio:inizio,dataFine:fine,spese,notaSpese,cassa,prelievo,tot,netto,quota,pags:pags.slice(),persone:state.persone.slice(),personeConQuota,savedAt:now};
  if((cassa||0)>0){
    state.movimentiCassa.push({data:now,tipo:'deposito',importo:cassa,note:'Da resoconto: '+periodoLabel,auto:true});
    state.saldoCassa+=cassa;
  }
  if((prelievo||0)>0){
    state.movimentiCassa.push({data:now,tipo:'prelievo',importo:prelievo,note:'Prelievo per resoconto: '+periodoLabel,auto:true});
    state.saldoCassa-=prelievo;
  }
  state.storico.unshift(r);
  window._lastResoconto=r;
  saveState();
  // Reset form
  document.getElementById('res-fine').value='';
  document.getElementById('res-spese').value='';
  document.getElementById('res-cassa').value='';
  document.getElementById('res-prelievo-cassa').value='';
  document.getElementById('res-nota-spese').value='';
  resMesiSelezionati=[];
  renderStorico();
  renderGestioneCassa();
  setDefaultDate();
  // Scorri allo storico
  document.querySelector('#page-resoconto .section-title[data-storico]')?.scrollIntoView({behavior:'smooth'});
  const storicoEl=document.getElementById('storico-table-wrap');
  if(storicoEl)storicoEl.scrollIntoView({behavior:'smooth',block:'start'});
}

function getStoricoDataFine(r){
  if(r.dataFine) return r.dataFine;
  if(r.periodoLabel){
    const m=r.periodoLabel.match(/(\d{2})-(\d{2})-(\d{4})\s*→\s*(\d{2})-(\d{2})-(\d{4})/);
    if(m) return `${m[6]}-${m[5]}-${m[4]}`;
  }
  return r.savedAt?r.savedAt.slice(0,10):null;
}

function getStoricoDataInizio(r){
  if(r.dataInizio) return r.dataInizio;
  if(r.periodoLabel){
    const m=r.periodoLabel.match(/^(\d{2})-(\d{2})-(\d{4})/);
    if(m) return `${m[3]}-${m[2]}-${m[1]}`;
  }
  return null;
}

function setFilResoconto(val){
  filResocontoVal=val;
  renderPagamenti();
}

function renderFilResoconto(){
  const sel=document.getElementById('fil-resoconto');
  if(!sel)return;
  sel.innerHTML='';

  function addOpt(parent,val,label){
    const o=document.createElement('option');
    o.value=val;o.textContent=label;
    parent.appendChild(o);
  }

  if(!state.storico||!state.storico.length){
    const oggi=new Date().toISOString().split('T')[0];
    addOpt(sel,oggi+'|','📅 Dal '+fmtData(oggi));
    filResocontoVal=oggi+'|';
    return;
  }

  addOpt(sel,'','🔍 Tutti i periodi');

  // Gruppo periodi chiusi
  const voci=[];
  state.storico.forEach(r=>{
    const fine=getStoricoDataFine(r);
    const inizio=getStoricoDataInizio(r);
    if(!fine)return;
    const key=(inizio||'')+'>'+fine;
    if(!voci.find(v=>v.key===key))voci.push({key,inizio,fine});
  });
  if(voci.length){
    const grp=document.createElement('optgroup');
    grp.label='── Periodi chiusi ──────────────';
    voci.forEach(v=>{
      addOpt(grp,v.key,v.inizio
        ?'🗓  '+fmtData(v.inizio)+'  →  '+fmtData(v.fine)
        :'🗓  Al '+fmtData(v.fine));
    });
    sel.appendChild(grp);
  }

  // Periodo corrente
  const ultimaFine=getStoricoDataFine(state.storico[0]);
  if(ultimaFine){
    const d=new Date(ultimaFine);d.setDate(d.getDate()+1);
    const dalGiorno=d.toISOString().split('T')[0];
    const grp=document.createElement('optgroup');
    grp.label='── Periodo corrente ────────────';
    addOpt(grp,dalGiorno+'|','▶  Dal '+fmtData(dalGiorno));
    sel.appendChild(grp);
    sel.value=dalGiorno+'|';
    filResocontoVal=dalGiorno+'|';
  }
}

function salvaResoconto(){
  if(!window._lastResoconto)return;
  const r=window._lastResoconto;
  const now=new Date().toISOString();
  if((r.cassa||0)>0){
    state.movimentiCassa.push({data:now,tipo:'deposito',importo:r.cassa,note:'Da resoconto: '+(r.periodoLabel||''),auto:true});
    state.saldoCassa+=r.cassa;
  }
  if((r.prelievo||0)>0){
    state.movimentiCassa.push({data:now,tipo:'prelievo',importo:r.prelievo,note:'Prelievo per resoconto: '+(r.periodoLabel||''),auto:true});
    state.saldoCassa-=r.prelievo;
  }
  state.storico.unshift({...r,savedAt:now});
  saveState();
  alert('Resoconto salvato nello storico!');
  renderStorico();
  renderGestioneCassa();
}

function esportaExcel(r){
  r=r||window._lastResoconto;if(!r)return;
  const wb=XLSX.utils.book_new();
  const personeConQuota=r.personeConQuota||(r.persone||[]).map(p=>({...p,quotaCalcolata:r.quota}));
  const ws1=XLSX.utils.aoa_to_sheet([['RESOCONTO IMMOBILI'],['Periodo',r.periodoLabel||''],[''],['Totale incassato',r.tot],['Spese dedotte',r.spese],...((r.cassa||0)>0?[['Quota in cassa',r.cassa]]:[]),...((r.prelievo||0)>0?[['Prelievo da cassa',r.prelievo]]:[]),['Netto da dividere',r.netto],[''],['DIVISIONE PER PERSONA'],...personeConQuota.map(p=>[p.nome+' ('+(p.quotaPatrimoniale||'—')+')',p.quotaCalcolata])]);
  ws1['!cols']=[{wch:28},{wch:18}];
  XLSX.utils.book_append_sheet(wb,ws1,'Riepilogo');
  const ws2=XLSX.utils.aoa_to_sheet([['Data pagamento','Mesi di riferimento','Inquilino','Immobile','Importo (€)','Note'],...(r.pags||[]).map(p=>[fmtData(p.data),mesiLabel(p.mesiRif),p.inquilino,p.immobile||'',p.importo,p.note||''])]);
  ws2['!cols']=[{wch:14},{wch:30},{wch:18},{wch:18},{wch:14},{wch:24}];
  XLSX.utils.book_append_sheet(wb,ws2,'Pagamenti');
  XLSX.writeFile(wb,'resoconto_'+new Date().toISOString().slice(0,10)+'.xlsx');
}

function stampaPDF(r){
  r=r||window._lastResoconto;if(!r)return;
  const personeConQuota=r.personeConQuota||(r.persone||[]).map(p=>({...p,quotaCalcolata:r.quota}));
  const persDiv=personeConQuota.map(p=>`<tr><td style="padding:6px 10px;border:1px solid #ddd">${p.nome}</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:center">${p.quotaPatrimoniale||'—'}</td><td style="padding:6px 10px;border:1px solid #ddd;text-align:right"><strong>${fmt(p.quotaCalcolata)}</strong></td></tr>`).join('');

  // Raggruppa pagamenti per inquilino
  const pags=r.pags||[];
  const gruppi={};
  pags.forEach(p=>{
    const k=p.inquilino||'N/D';
    if(!gruppi[k])gruppi[k]={inquilino:k,immobile:p.immobile||'-',pags:[],tot:0};
    gruppi[k].pags.push(p);
    gruppi[k].tot+=p.importo;
  });
  const COLORS=['#2a6496','#178a5a','#8e44ad','#d35400','#16a085','#c0392b','#2980b9'];
  const dettaglioHtml=Object.values(gruppi).map((g,gi)=>{
    const colore=COLORS[gi%COLORS.length];
    const righe=g.pags.map(p=>`<tr>
      <td style="padding:5px 8px;border:1px solid #ddd;white-space:nowrap;overflow:hidden">${fmtData(p.data)}</td>
      <td style="padding:5px 8px;border:1px solid #ddd;word-wrap:break-word">${mesiLabel(p.mesiRif)}</td>
      <td style="padding:5px 8px;border:1px solid #ddd;color:#666;word-wrap:break-word">${p.note||'-'}</td>
      <td style="padding:5px 8px;border:1px solid #ddd;text-align:right;font-weight:600;white-space:nowrap">${fmt(p.importo)}</td>
    </tr>`).join('');
    return `
      <div style="margin-top:18px;border-left:4px solid ${colore};padding-left:10px;page-break-inside:avoid;break-inside:avoid">
        <div style="font-weight:700;font-size:14px;color:${colore};margin-bottom:4px">
          👤 ${g.inquilino} &nbsp;<span style="font-size:12px;color:#555;font-weight:400">— ${g.immobile}</span>
          <span style="float:right;font-size:13px;color:#222">Totale: <strong>${fmt(g.tot)}</strong></span>
        </div>
        <table style="width:100%;table-layout:fixed;border-collapse:collapse;font-size:12px">
          <thead><tr>
            <th style="width:90px;white-space:nowrap">Data</th>
            <th style="width:160px">Mesi rif.</th>
            <th style="width:50%">Note</th>
            <th style="text-align:right;width:90px;white-space:nowrap">Importo</th>
          </tr></thead>
          <tbody>${righe}</tbody>
        </table>
      </div>`;
  }).join('');

  // Tabella spese del periodo (da state.spese live, filtrate per date resoconto)
  const speseDelPeriodo=(state.spese||[])
    .filter(s=>s.data>=(r.dataInizio||'')&&s.data<=(r.dataFine||'9999'))
    .sort((a,b)=>a.data.localeCompare(b.data));
  const speseHtml=speseDelPeriodo.length
    ?`<table>
        <thead><tr>
          <th style="width:110px">Data</th>
          <th>Descrizione</th>
          <th style="text-align:right;width:120px">Importo</th>
        </tr></thead>
        <tbody>
          ${speseDelPeriodo.map((s,idx)=>`<tr${idx%2===1?' style="background:#f5f9fd"':''}>
            <td style="white-space:nowrap">${fmtData(s.data)}</td>
            <td>${s.note?s.note.replace(/</g,'&lt;'):'-'}</td>
            <td style="text-align:right;font-weight:600;color:#c0392b">${fmt(s.importo)}</td>
          </tr>`).join('')}
          <tr style="background:#fff3cd">
            <td colspan="2" style="font-weight:700;text-align:right">Totale spese</td>
            <td style="text-align:right;font-weight:800;color:#c0392b">${fmt(speseDelPeriodo.reduce((t,s)=>t+s.importo,0))}</td>
          </tr>
        </tbody>
      </table>`
    :'<div style="color:#999;font-style:italic;padding:8px 0">Nessuna spesa registrata nel periodo.</div>';

  // Formula netto (visibile solo se c'è prelievo da cassa)
  const formulaHtml=(r.prelievo||0)>0?`<div style="margin-top:6px;font-size:12px;color:#555;padding:5px 10px;background:#f0f8f4;border-radius:4px;display:inline-block">
    🧮 ${fmt(r.tot)} − ${fmt(r.spese)} − ${fmt(r.cassa||0)} + <span style="color:#1a6b3a;font-weight:700">${fmt(r.prelievo)} (prelievo cassa)</span> = <strong>${fmt(r.netto)}</strong>
  </div>`:'';

  const _html=`<!DOCTYPE html><html><head><meta charset="utf-8"><title>Resoconto Incassi</title><style>
    body{font-family:Arial,sans-serif;font-size:13px;color:#222;padding:30px;max-width:960px;margin:0 auto}
    .header-box{text-align:center;border:2px solid #2a6496;border-radius:10px;padding:18px 24px;margin-bottom:20px;background:linear-gradient(135deg,#eef4fb,#dceef9)}
    .header-box h1{margin:0 0 6px 0;font-size:23px;color:#1e4f78;letter-spacing:.3px}
    .header-box .subtitle{color:#555;font-size:13px}
    .btn-stampa{display:block;margin:0 0 16px auto;padding:8px 20px;background:#c0392b;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px;white-space:nowrap}
    h2{font-size:15px;margin:22px 0 8px;padding:7px 12px;background:#dceef9;border-left:4px solid #2a6496;border-radius:0 5px 5px 0;color:#1e4f78;font-weight:700}
    table{border-collapse:collapse;width:100%;margin-bottom:6px}
    th{background:#2a6496;color:#fff;font-weight:700;padding:9px 12px;border:1px solid #1e4f78;font-size:12px;text-align:left;white-space:nowrap;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    td{padding:7px 10px;border:1px solid #ddd;font-size:12px;vertical-align:top}
    tr:nth-child(even) td{background:#f5f9fd}
    .summary-outer{border:2px solid #2a6496;border-radius:10px;padding:16px 20px;margin:16px 0;background:#f7fafd;text-align:center}
    .summary-outer .summary-title{font-size:11px;font-weight:700;color:#2a6496;text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px}
    .summary{display:inline-flex;gap:16px;flex-wrap:wrap;justify-content:center}
    .summary-extra{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:10px}
    .box{border:1px solid #ddd;border-radius:6px;padding:10px 16px;min-width:130px;text-align:center;background:#fff}
    .box-label{font-size:11px;color:#666;margin-bottom:2px}
    .box-val{font-size:18px;font-weight:bold}
    .netto{background:#e6f4ed;border-color:#1a6b3a}
    .footer{margin-top:30px;font-size:11px;color:#999;border-top:1px solid #eee;padding-top:10px}
    @page{margin:22mm 15mm}
    @page :first{margin:12mm 15mm}
    @media print{.btn-stampa{display:none} div[style*="border-left"]{page-break-inside:avoid;break-inside:avoid} body{-webkit-print-color-adjust:exact;print-color-adjust:exact}}
  </style></head><body>
  <button class="btn-stampa" onclick="window.print()">🖨 Stampa / Salva PDF</button>
  <div class="header-box">
    <h1>📊 Resoconto Incassi Immobili</h1>
    <div class="subtitle">Periodo: <strong>${(r.periodoLabel||'').replace(/\s*\(per [^)]+\)/,'')}</strong></div>
  </div>
  <div class="summary-outer">
    <div class="summary-title">📊 Riepilogo periodo</div>
    <div class="summary">
      <div class="box"><div class="box-label">Totale incassato</div><div class="box-val">${fmt(r.tot)}</div></div>
      <div class="box"><div class="box-label">Spese dedotte</div><div class="box-val" style="color:#c0392b">${fmt(r.spese)}</div></div>
      <div class="box netto"><div class="box-label">Netto da dividere</div><div class="box-val" style="color:#178a5a">${fmt(r.netto)}</div></div>
    </div>
    ${(r.prelievo||0)>0||(r.cassa||0)>0?`<div class="summary-extra">
      ${(r.prelievo||0)>0?`<div class="box" style="border-color:#1a6b3a;background:#f0f8f4"><div class="box-label">📤 Prelievo dalla Cassa</div><div class="box-val" style="color:#1a6b3a">${fmt(r.prelievo)}</div><div style="font-size:10px;color:#1a6b3a;margin-top:2px">contribuisce al netto</div></div>`:''}
      ${(r.cassa||0)>0?`<div class="box" style="border-color:#e67e22;background:#fdf6ec"><div class="box-label">💰 Quota versata in Cassa</div><div class="box-val" style="color:#e67e22">${fmt(r.cassa)}</div></div>`:''}
    </div>`:''}
  </div>
  ${formulaHtml}
  <h2>Suddivisione Quote</h2>
  <table><thead><tr>
    <th>Erede</th>
    <th style="text-align:center">Quota Patrim.</th>
    <th style="text-align:right">Importo</th>
  </tr></thead><tbody>${persDiv}</tbody></table>
  <h2>🧾 Spese Periodo</h2>${speseHtml}
  <h2>Dettaglio Incassi per inquilino</h2>
  ${dettaglioHtml}
  <div class="footer">Totale pagamenti: ${pags.length} &nbsp;|&nbsp; Inquilini: ${Object.keys(gruppi).length} &nbsp;|&nbsp; Totale incassato: ${fmt(r.tot)}</div>
  </body></html>`;
  const newWin=window.open('','_blank');
  if(newWin){newWin.document.open();newWin.document.write(_html);newWin.document.close();}
}

function renderStorico(){
  const el=document.getElementById('storico-list');
  if(!state.storico.length){el.innerHTML='<div class="empty">Nessun resoconto salvato ancora.</div>';populateFiltriStorico();return;}

  populateFiltriStorico();

  const filtAnno=(document.getElementById('fil-storico-anno')||{}).value||'';
  const filtPeriodo=(document.getElementById('fil-storico-periodo')||{}).value||'';

  // Indici originali preservati per eliminaResoconto
  const filtered=state.storico.map((r,i)=>({r,i})).filter(({r})=>{
    const fine=getStoricoDataFine(r)||'';
    const inizio=r.dataInizio||'';
    const anno=fine?fine.slice(0,4):(inizio?inizio.slice(0,4):'');
    if(filtAnno&&anno!==filtAnno)return false;
    if(filtPeriodo){
      const key=(inizio||'')+'>'+fine;
      if(key!==filtPeriodo)return false;
    }
    return true;
  });

  if(!filtered.length){el.innerHTML='<div class="empty">Nessun resoconto per il filtro selezionato.</div>';return;}

  const hasCassa=filtered.some(({r})=>(r.cassa||0)>0);
  const hasPrelievo=filtered.some(({r})=>(r.prelievo||0)>0);

  const rows=filtered.map(({r,i})=>{
    const persConQ=r.personeConQuota||(r.persone||[]).map(p=>({...p,quotaCalcolata:r.quota}));
    const persStr=persConQ.map(p=>`<span>${p.nome||'?'}: <strong>${fmt(p.quotaCalcolata)}</strong>${p.quotaPatrimoniale?' ('+p.quotaPatrimoniale+')':''}</span>`).join('<br>');
    const dataFineISO=getStoricoDataFine(r);
    const dataFineLabel=dataFineISO?fmtData(dataFineISO):'-';
    let dataInizioLabel='-';
    if(r.dataInizio) dataInizioLabel=fmtData(r.dataInizio);
    else if(r.periodoLabel){const m=r.periodoLabel.match(/^(\d{2}-\d{2}-\d{4})/);if(m)dataInizioLabel=m[1];}
    const tipoLabel=r.periodoLabel&&r.periodoLabel.includes('mese')
      ?'<span class="badge-periodo">per mese rif.</span>'
      :'<span class="badge-periodo">per data pag.</span>';

    const notes=r.notaSpese?r.notaSpese.split('\n').filter(n=>n.trim()):[];
    const rs=Math.max(1,notes.length);
    const rsAttr=rs>1?` rowspan="${rs}"`:'';
    const notaTdStyle='font-size:12px;color:var(--color-text-secondary);max-width:180px;vertical-align:top';

    const fmtNota=n=>n.replace(/(\(€[^)]+\))/g,'<strong>$1</strong>');

    const firstNoteTd=notes.length
      ?`<td style="${notaTdStyle}">${fmtNota(notes[0])}</td>`
      :`<td style="${notaTdStyle}"><span style="color:var(--color-text-tertiary)">-</span></td>`;

    const extraRows=notes.slice(1).map(n=>
      `<tr><td style="${notaTdStyle};border-top:1px dashed #d0d7e0">${fmtNota(n)}</td></tr>`
    ).join('');

    return `<tr>
      <td style="white-space:nowrap"${rsAttr}>${new Date(r.savedAt).toLocaleDateString('it-IT')}</td>
      <td style="white-space:nowrap"${rsAttr}>${dataInizioLabel}</td>
      <td style="white-space:nowrap"${rsAttr}>${dataFineLabel}</td>
      <td style="text-align:right;font-weight:600"${rsAttr}>${fmt(r.tot)}</td>
      <td style="text-align:right;color:#c0392b;font-weight:700"${rsAttr}>${fmt(r.spese)}</td>
      ${firstNoteTd}
      ${hasCassa?`<td style="text-align:right"${rsAttr}>${(r.cassa||0)>0?fmt(r.cassa):'-'}</td>`:''}
      ${hasPrelievo?`<td style="text-align:right;color:#1a6b3a;font-weight:600"${rsAttr}>${(r.prelievo||0)>0?fmt(r.prelievo):'-'}</td>`:''}
      <td style="text-align:right;font-weight:700;color:#178a5a"${rsAttr}>${fmt(r.netto)}</td>
      <td class="persone-cell"${rsAttr}>${persStr||'-'}</td>
      <td style="text-align:center;white-space:nowrap"${rsAttr}>
        <div style="display:flex;gap:4px;justify-content:center;align-items:center">
          <button class="btn btn-sm btn-excel" onclick="esportaExcel(state.storico[${i}])" title="Esporta Excel">XLS</button>
          <button class="btn btn-sm btn-pdf" onclick="stampaPDF(state.storico[${i}])" title="Stampa PDF">PDF</button>
          <button class="btn btn-sm btn-danger" onclick="eliminaResoconto(${i})" title="Elimina">✕</button>
        </div>
      </td>
    </tr>${extraRows}`;
  }).join('');
  el.innerHTML=`
    <div class="table-wrap">
      <table id="storico-table">
        <thead>
          <tr>
            <th>Salvato il</th><th>Da</th><th>A</th>
            <th style="text-align:right">Incassato</th><th style="text-align:right">Spese</th>
            <th>Nota spese</th>
            ${hasCassa?'<th style="text-align:right">Depositato in cassa</th>':''}
            ${hasPrelievo?'<th style="text-align:right">Prelevato dalla cassa</th>':''}
            <th style="text-align:right">Netto diviso</th>
            <th>Divisione</th><th style="text-align:center;width:90px">Azioni</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
}

function populateFiltriStorico(){
  const selAnno=document.getElementById('fil-storico-anno');
  const selPeriodo=document.getElementById('fil-storico-periodo');
  if(!selAnno||!selPeriodo)return;
  const prevAnno=selAnno.value, prevPeriodo=selPeriodo.value;

  // Anni unici
  const anni=new Set();
  state.storico.forEach(r=>{
    const fine=getStoricoDataFine(r)||'';
    const inizio=r.dataInizio||'';
    const a=fine?fine.slice(0,4):(inizio?inizio.slice(0,4):'');
    if(a)anni.add(a);
  });
  selAnno.innerHTML='<option value="">Tutti gli anni</option>';
  [...anni].sort((a,b)=>b-a).forEach(a=>{
    const o=document.createElement('option');o.value=a;o.textContent=a;selAnno.appendChild(o);
  });
  if(prevAnno)selAnno.value=prevAnno;

  // Periodi unici (deduplicati)
  const periodi=[];
  state.storico.forEach(r=>{
    const fine=getStoricoDataFine(r)||'';
    const inizio=r.dataInizio||'';
    const key=(inizio||'')+'>'+fine;
    if(fine&&!periodi.find(p=>p.key===key))periodi.push({key,inizio,fine});
  });
  selPeriodo.innerHTML='<option value="">Tutti i periodi</option>';
  periodi.forEach(p=>{
    const o=document.createElement('option');
    o.value=p.key;
    o.textContent=p.inizio?'🗓 '+fmtData(p.inizio)+' → '+fmtData(p.fine):'🗓 Al '+fmtData(p.fine);
    selPeriodo.appendChild(o);
  });
  if(prevPeriodo)selPeriodo.value=prevPeriodo;
}

function resetFiltriStorico(){
  const sa=document.getElementById('fil-storico-anno');
  const sp=document.getElementById('fil-storico-periodo');
  if(sa)sa.value='';if(sp)sp.value='';
  renderStorico();
}

function eliminaResoconto(i){
  if(!confirm('Eliminare questo resoconto?'))return;
  const r=state.storico[i];
  // Annulla i movimenti cassa automatici associati a questo resoconto
  const label=r.periodoLabel||'';
  const noteDeposito='Da resoconto: '+label;
  const notePrelievo='Prelievo per resoconto: '+label;
  state.movimentiCassa=state.movimentiCassa.filter(m=>{
    if(m.auto&&m.tipo==='deposito'&&m.note===noteDeposito){state.saldoCassa-=m.importo;return false;}
    if(m.auto&&m.tipo==='prelievo'&&m.note===notePrelievo){state.saldoCassa+=m.importo;return false;}
    return true;
  });
  state.storico.splice(i,1);saveState();renderStorico();renderGestioneCassa();setDefaultDate();
}

// ── BACKUP & RIPRISTINO ────────────────────────────────────────
function esportaDatiJSON(){
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='incassi-dati-'+new Date().toISOString().slice(0,10)+'.json';
  a.click();
}

// ── BACKUP AUTOMATICO (IndexedDB) ────────────────────────────
(function(){
  const DB='incassi_idb', STORE='backups', MAX=5;
  function openDB(){
    return new Promise((res,rej)=>{
      const req=indexedDB.open(DB,1);
      req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains(STORE))db.createObjectStore(STORE);};
      req.onsuccess=e=>res(e.target.result);
      req.onerror=()=>rej(req.error);
    });
  }
  async function getAllBackups(){
    const db=await openDB();
    return new Promise((res,rej)=>{
      const tx=db.transaction(STORE,'readonly');
      const r=tx.objectStore(STORE).getAll();
      const rk=tx.objectStore(STORE).getAllKeys();
      let vals,keys;
      r.onsuccess=()=>{vals=r.result;if(keys!==undefined)res(keys.map((k,i)=>({key:k,ts:vals[i].ts,data:vals[i].data})));};
      rk.onsuccess=()=>{keys=rk.result;if(vals!==undefined)res(keys.map((k,i)=>({key:k,ts:vals[i].ts,data:vals[i].data})));};
      tx.onerror=()=>rej(tx.error);
    });
  }
  async function doBackup(){
    try{
      const db=await openDB();
      const now=new Date();
      const key='bk_'+now.toISOString().replace(/[:.]/g,'-');
      await new Promise((res,rej)=>{const tx=db.transaction(STORE,'readwrite');tx.objectStore(STORE).put({ts:now.toISOString(),data:JSON.stringify(state)},key);tx.oncomplete=res;tx.onerror=()=>rej(tx.error);});
      const allKeys=await new Promise((res,rej)=>{const tx=db.transaction(STORE,'readonly');const r=tx.objectStore(STORE).getAllKeys();r.onsuccess=()=>res(r.result);r.onerror=()=>rej(r.error);});
      allKeys.sort();
      if(allKeys.length>MAX){
        const toDelete=allKeys.slice(0,allKeys.length-MAX);
        const tx=db.transaction(STORE,'readwrite');
        toDelete.forEach(k=>tx.objectStore(STORE).delete(k));
      }
      const hms=now.toTimeString().slice(0,8);
      const cnt=Math.min(allKeys.length,MAX);
      const el=document.getElementById('export-status');
      if(el)el.textContent='✅ Backup automatico attivo — ultimo: '+hms+' ('+cnt+' cop'+(cnt===1?'ia':'ie')+' conservate)';
    }catch(e){console.warn('Backup IDB fallito:',e);}
  }
  function initAutoExport(){doBackup();setInterval(doBackup,3600000);}
  window.initAutoExport=initAutoExport;
  window.mostraListaBackup=async function(){
    const el=document.getElementById('backup-list');
    if(!el)return;
    el.innerHTML='<span style="color:#888;font-size:13px">Caricamento…</span>';
    try{
      const list=await getAllBackups();
      list.sort((a,b)=>b.key.localeCompare(a.key)); // più recente prima
      if(!list.length){el.innerHTML='<span style="color:#888;font-size:13px">Nessuna copia disponibile ancora — attendi il primo ciclo (60s).</span>';return;}
      const rows=list.map((b,i)=>{
        const d=new Date(b.ts);
        const label=d.toLocaleDateString('it-IT')+' alle '+d.toTimeString().slice(0,8);
        const parsed=JSON.parse(b.data);
        const info=(parsed.pagamenti||[]).length+' pagamenti, '+(parsed.immobili||[]).length+' immobili';
        return `<tr>
          <td style="padding:8px 10px;font-weight:600">${i===0?'🟢 Più recente':'🔵 Copia '+(i+1)}</td>
          <td style="padding:8px 10px">${label}</td>
          <td style="padding:8px 10px;color:#666;font-size:12px">${info}</td>
          <td style="padding:8px 10px">
            <button class="btn btn-sm btn-edit" onclick="ripristinaBackup('${b.key}')" title="Ripristina questo backup">↩️ Ripristina</button>
            <button class="btn btn-sm btn-excel" onclick="scaricaBackup('${b.key}')" title="Scarica come JSON">⬇ JSON</button>
          </td>
        </tr>`;
      }).join('');
      el.innerHTML=`<table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead><tr style="background:#f0f0f0"><th style="padding:6px 10px;text-align:left">Copia</th><th style="padding:6px 10px;text-align:left">Data e ora</th><th style="padding:6px 10px;text-align:left">Contenuto</th><th style="padding:6px 10px;text-align:left">Azioni</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
    }catch(e){el.innerHTML='<span style="color:red;font-size:13px">Errore accesso backup: '+e.message+'</span>';}
  };
  window.ripristinaBackup=async function(key){
    if(!confirm('Ripristinare i dati da questa copia?\n\nI dati attuali verranno sovrascritti. Considera di esportare prima un JSON di sicurezza.'))return;
    try{
      const list=await getAllBackups();
      const b=list.find(x=>x.key===key);
      if(!b){alert('Copia non trovata.');return;}
      const imp=JSON.parse(b.data);
      ['immobili','persone','pagamenti','storico'].forEach(k=>{if(!imp[k])imp[k]=[];});
      if(!imp.movimentiCassa)imp.movimentiCassa=[];
      if(typeof imp.saldoCassa!=='number')imp.saldoCassa=0;
      state=imp;saveState();
      renderImmobili();renderPersone();renderSelInquilino();
      alert('✅ Ripristino completato!\n\n'+( imp.pagamenti.length)+' pagamenti, '+(imp.immobili.length)+' immobili caricati.');
      mostraListaBackup();
    }catch(e){alert('Errore durante il ripristino: '+e.message);}
  };
  window.scaricaBackup=async function(key){
    const list=await getAllBackups();
    const b=list.find(x=>x.key===key);
    if(!b)return;
    const d=new Date(b.ts);
    const fname='backup-'+d.toISOString().slice(0,16).replace('T','_').replace(':','-')+'.json';
    const blob=new Blob([b.data],{type:'application/json'});
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=fname;a.click();
  };
})();

function salvaFileSelfContained(input){}

function importaDatiJSON(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const imp=JSON.parse(e.target.result);
      ['immobili','persone','pagamenti','storico'].forEach(k=>{if(!imp[k])imp[k]=[];});
      if(!imp.movimentiCassa)imp.movimentiCassa=[];
      if(typeof imp.saldoCassa!=='number')imp.saldoCassa=0;
      state=imp;saveState();
      renderImmobili();renderPersone();
      alert('Dati importati correttamente! ('+state.pagamenti.length+' pagamenti, '+state.immobili.length+' immobili)');
    }catch(err){alert('Errore: file JSON non valido.');}
  };
  reader.readAsText(file);
  input.value='';
}


// ── GESTIONE CASSA ────────────────────────────────────────────
function renderGestioneCassa(){
  const saldo=state.saldoCassa||0;
  const el=document.getElementById('gc-saldo');
  if(el) el.textContent=fmt(saldo);
  const box=document.getElementById('gc-saldo-box');
  if(box) box.className='cassa-saldo-box'+(saldo<0?' negativo':'');
  const wrap=document.getElementById('gc-movimenti-wrap');
  if(!wrap)return;
  if(!(state.movimentiCassa||[]).length){wrap.innerHTML='<div class="empty">Nessun movimento registrato.</div>';return;}
  const filTipo=(document.getElementById('gc-fil-tipo')||{}).value||'';
  const filDal=(document.getElementById('gc-fil-dal')||{}).value||'';
  const filAl=(document.getElementById('gc-fil-al')||{}).value||'';
  const filtered=[...state.movimentiCassa].map((m,idx)=>({m,idx})).reverse().filter(({m})=>{
    if(filTipo&&m.tipo!==filTipo)return false;
    const d=m.data?m.data.slice(0,10):'';
    if(filDal&&d<filDal)return false;
    if(filAl&&d>filAl)return false;
    return true;
  });
  if(!filtered.length){wrap.innerHTML='<div class="empty">Nessun movimento trovato con i filtri selezionati.</div>';return;}
  const rows=filtered.map(({m,idx})=>{
    const isDeposito=m.tipo==='deposito';
    const colore=isDeposito?'#178a5a':'#c0392b';
    const icona=isDeposito?'📥 Deposito':'📤 Prelievo';
    const segno=isDeposito?'+':'-';
    const delBtn=m.auto
      ?`<td style="text-align:center;white-space:nowrap"><span style="font-size:11px;color:var(--color-text-tertiary)">auto</span></td>`
      :`<td style="text-align:center;white-space:nowrap"><div style="display:flex;gap:4px;justify-content:center;align-items:center"><button class="btn btn-sm btn-edit" onclick="apriModificaMovimentoCassa(${idx})" title="Modifica">✏️</button><button class="btn btn-sm btn-danger" onclick="rimuoviMovimentoCassa(${idx})">✕</button></div></td>`;
    return `<tr>
      <td>${new Date(m.data).toLocaleDateString('it-IT')}</td>
      <td><span style="color:${colore};font-weight:700">${icona}</span></td>
      <td style="text-align:right;color:${colore};font-weight:700">${segno}${fmt(m.importo)}</td>
      <td style="font-size:12px">${m.note||'-'}</td>
      ${delBtn}
    </tr>`;
  }).join('');
  wrap.innerHTML=`<div class="table-wrap"><table>
    <thead><tr><th>Data</th><th>Tipo</th><th style="text-align:right">Importo</th><th>Nota</th><th style="text-align:center;width:90px">Azioni</th></tr></thead>
    <tbody>${rows}</tbody>
  </table></div>`;
}

function resetFiltriCassa(){
  const t=document.getElementById('gc-fil-tipo');if(t)t.value='';
  const d=document.getElementById('gc-fil-dal');if(d)d.value='';
  const a=document.getElementById('gc-fil-al');if(a)a.value='';
  renderGestioneCassa();
}

function annullaMovimentoCassa(){
  document.getElementById('gc-tipo').value='deposito';
  document.getElementById('gc-importo').value='';
  document.getElementById('gc-nota').value='';
}

let _modCassaIdx=null;
function apriModificaMovimentoCassa(idx){
  const m=state.movimentiCassa[idx];
  if(!m)return;
  _modCassaIdx=idx;
  document.getElementById('mc-tipo').value=m.tipo;
  document.getElementById('mc-importo').value=m.importo;
  document.getElementById('mc-nota').value=m.note||'';
  document.getElementById('mc-data').value=m.data?m.data.split('T')[0]:'';
  document.getElementById('modal-mov-cassa').style.display='flex';
}
function chiudiModaleMovimentoCassa(){
  document.getElementById('modal-mov-cassa').style.display='none';
  _modCassaIdx=null;
}
function salvaModificaMovimentoCassa(){
  if(_modCassaIdx===null)return;
  const m=state.movimentiCassa[_modCassaIdx];
  const nuovoTipo=document.getElementById('mc-tipo').value;
  const nuovoImporto=parseFloat(document.getElementById('mc-importo').value);
  if(!nuovoImporto||nuovoImporto<=0){alert('Inserisci un importo valido.');return;}
  // aggiorna saldo: annulla vecchio
  if(m.tipo==='deposito')state.saldoCassa-=m.importo; else state.saldoCassa+=m.importo;
  // applica nuovo
  if(nuovoTipo==='deposito')state.saldoCassa+=nuovoImporto; else state.saldoCassa-=nuovoImporto;
  m.tipo=nuovoTipo;
  m.importo=nuovoImporto;
  m.note=document.getElementById('mc-nota').value.trim();
  const dataVal=document.getElementById('mc-data').value;
  if(dataVal) m.data=new Date(dataVal).toISOString();
  saveState();
  chiudiModaleMovimentoCassa();
  renderGestioneCassa();
}

function aggiungiMovimentoCassa(){
  const tipo=document.getElementById('gc-tipo').value;
  const importo=parseFloat(document.getElementById('gc-importo').value);
  const nota=(document.getElementById('gc-nota').value||'').trim();
  if(!importo||importo<=0){alert('Inserisci un importo valido.');return;}
  state.movimentiCassa.push({data:new Date().toISOString(),tipo,importo,note:nota,auto:false});
  if(tipo==='deposito')state.saldoCassa+=importo;
  else state.saldoCassa-=importo;
  saveState();
  document.getElementById('gc-importo').value='';
  document.getElementById('gc-nota').value='';
  renderGestioneCassa();
}

function rimuoviMovimentoCassa(i){
  if(!confirm('Rimuovere questo movimento?'))return;
  const m=state.movimentiCassa[i];
  if(m.tipo==='deposito')state.saldoCassa-=m.importo;
  else state.saldoCassa+=m.importo;
  state.movimentiCassa.splice(i,1);
  saveState();renderGestioneCassa();
}

// ── INIZIALIZZAZIONE ────────────────────────────────────────
loadState();
renderImmobili();
renderPersone();
renderSelInquilino();
showPage('home');
initAutoExport();
initCloudSync();
setInterval(()=>{
  const{token,gistId}=getGistConfig();
  if(token&&gistId)initCloudSync();
},30000);

function renderReport(){
  const dal=document.getElementById('rep-dal').value;
  const al=document.getElementById('rep-al').value;
  const wrap=document.getElementById('report-wrap');
  const btnStampa=document.getElementById('btn-stampa-report');
  if(!dal||!al){wrap.innerHTML='<div class="empty" style="padding:16px">Seleziona il periodo dal e al.</div>';btnStampa.style.display='none';return;}
  if(dal>al){wrap.innerHTML='<div class="empty" style="padding:16px">Il mese di inizio deve essere precedente o uguale al mese di fine.</div>';btnStampa.style.display='none';return;}
  // Genera lista mesi nel periodo
  const mesi=[];
  let [yy,mm]=dal.split('-').map(Number);
  const [ye,me]=al.split('-').map(Number);
  while(yy<ye||(yy===ye&&mm<=me)){
    mesi.push(yy+'-'+String(mm).padStart(2,'0'));
    mm++;if(mm>12){mm=1;yy++;}
  }
  // Inquilini attivi (unici, con nome)
  const inquilini=[...new Map((state.immobili||[]).filter(i=>i.inquilino).map(i=>[i.inquilino,i])).values()];
  if(!inquilini.length){wrap.innerHTML='<div class="empty" style="padding:16px">Nessun inquilino in anagrafica.</div>';btnStampa.style.display='none';return;}
  // Costruisci indice: "YYYY-MM|inquilino" → {n, storico}
  // Un pagamento è "storico" se la sua data cade dentro un periodo chiuso
  const rangeChiusi=(state.storico||[]).map(r=>({
    inizio:getStoricoDataInizio(r)||'',
    fine:getStoricoDataFine(r)||''
  })).filter(r=>r.fine);
  const idxN=new Map();
  const idxStorico=new Set();
  (state.pagamenti||[]).forEach(p=>{
    const pData=p.data||'';
    const isChiuso=rangeChiusi.some(r=>(!r.inizio||pData>=r.inizio)&&pData<=r.fine);
    (p.mesiRif||[]).forEach(k=>{
      const key=k+'|'+p.inquilino;
      idxN.set(key,(idxN.get(key)||0)+1);
      if(isChiuso)idxStorico.add(key);
    });
  });
  // Render tabella
  let html='<table><thead><tr><th class="col-mese">Mese / Inquilino</th>';
  inquilini.forEach(i=>{html+=`<th title="${i.nome||''}">${i.inquilino}</th>`;});
  html+='</tr></thead><tbody>';
  mesi.forEach(mk=>{
    const [y,m]=mk.split('-');
    const label=MESI[parseInt(m)-1]+' '+y;
    html+=`<tr><td class="col-mese">${label}</td>`;
    inquilini.forEach(i=>{
      const key=mk+'|'+i.inquilino;
      const n=idxN.get(key)||0;
      if(n===0) html+='<td class="no">–</td>';
      else if(n===1) html+=`<td class="${idxStorico.has(key)?'ok':'ok-corrente'}">✔</td>`;
      else html+=`<td class="dup" title="${n} pagamenti registrati">🔴</td>`;
    });
    html+='</tr>';
  });
  html+='</tbody></table>';
  wrap.innerHTML=html;
  btnStampa.style.display='inline-flex';
}

function stampaReport(){
  const dal=document.getElementById('rep-dal').value;
  const al=document.getElementById('rep-al').value;
  const [yd,md]=dal.split('-');const [ya,ma]=al.split('-');
  const titolo='Report Incassi — '+MESI[parseInt(md)-1]+' '+yd+' / '+MESI[parseInt(ma)-1]+' '+ya;
  const tableHtml=document.getElementById('report-wrap').innerHTML;
  const w=window.open('','_blank','width=1100,height=700');
  w.document.write(`<!DOCTYPE html><html><head><meta charset="utf-8">
  <title>${titolo}</title>
  <style>
    @page{size:A4 landscape;margin:1cm}
    body{font-family:Arial,sans-serif;font-size:12px;margin:0;padding:12px}
    h2{font-size:15px;margin:0 0 12px;color:#0e4a28}
    table{border-collapse:collapse;width:100%}
    th{background:#178a5a;color:#fff;padding:7px 9px;text-align:center;border:1px solid #0e6644;font-weight:600;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    th.col-mese{background:#e67e22;text-align:left;min-width:120px}
    td{padding:6px 9px;text-align:center;border:1px solid #c8ddd0}
    td.col-mese{text-align:left;font-weight:700;background:#178a5a;color:#fff;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    td.ok{background:#d4edda;color:#155724;font-weight:700;font-size:14px;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    td.ok-corrente{background:#ffc107;color:#5a3600;font-weight:700;font-size:14px;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    td.dup{background:#fde8e8;font-size:15px;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    td.no{color:#bbb}
  </style></head><body>
  <h2>📈 ${titolo}</h2>
  <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;margin-bottom:12px;font-size:11px;font-weight:600;-webkit-print-color-adjust:exact;print-color-adjust:exact">
    <span style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:14px;height:14px;border-radius:2px;background:#178a5a;border:1px solid #0e6644"></span>Mese</span>
    <span style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:14px;height:14px;border-radius:2px;background:#d4edda;border:1px solid #b2d8bc"></span>Pagato – periodo chiuso</span>
    <span style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:14px;height:14px;border-radius:2px;background:#ffc107;border:1px solid #e6a800"></span>Pagato – periodo aperto</span>
    <span style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:14px;height:14px;border-radius:2px;background:#f8f9fa;border:1px solid #ccc"></span>Non pagato</span>
    <span style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:14px;height:14px;border-radius:2px;background:#fde8e8;border:1px solid #f5c6cb"></span>Duplicato</span>
  </div>
  ${tableHtml}
  <script>window.onload=function(){window.print();}<\/script>
  </body></html>`);
  w.document.close();
}

function initReport(){
  const oggi=new Date();
  // Ultimi 12 mesi: dal mese corrente -11 al mese corrente
  const fine=new Date(oggi.getFullYear(),oggi.getMonth(),1);
  const inizio=new Date(fine);
  inizio.setMonth(inizio.getMonth()-11);
  const fmt=d=>d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
  document.getElementById('rep-dal').value=fmt(inizio);
  document.getElementById('rep-al').value=fmt(fine);
}


// ══ AUTH: LOGOUT + CAMBIA PASSWORD ══
const _STATICRYPT_TEMPLATE_B64 = '';
const _STATICRYPT_SALT = 'd0a92d7e974afb816ec3d60da092be56';

function eseguiLogout() {
  if(!confirm('Vuoi uscire dalla sessione?')) return;
  localStorage.removeItem('staticrypt_passphrase');
  localStorage.removeItem('staticrypt_expiration');
  location.reload();
}

async function cambiaPassword() {
  const np = document.getElementById('cp-new').value;
  const nc = document.getElementById('cp-confirm').value;
  const msg = document.getElementById('cp-msg');

  if(!np || np.length < 6) { msg.style.color='#c0392b'; msg.textContent='⚠️ La password deve essere di almeno 6 caratteri.'; return; }
  if(np !== nc) { msg.style.color='#c0392b'; msg.textContent='⚠️ Le password non coincidono.'; return; }

  msg.style.color='#2a6496'; msg.textContent='⏳ Cifratura in corso…';

  try {
    const subtle = window.crypto.subtle;
    const enc = new TextEncoder();
    const hex = arr => Array.from(arr).map(b => b.toString(16).padStart(2,'0')).join('');

    // PBKDF2 — round 1 (SHA-1, 1000 it)
    const k1 = await subtle.importKey('raw', enc.encode(np), 'PBKDF2', false, ['deriveBits']);
    const h1buf = await subtle.deriveBits({name:'PBKDF2',hash:'SHA-1',iterations:1000,salt:enc.encode(_STATICRYPT_SALT)}, k1, 256);
    const h1 = hex(new Uint8Array(h1buf));

    // round 2 (SHA-256, 14000 it)
    const k2 = await subtle.importKey('raw', enc.encode(h1), 'PBKDF2', false, ['deriveBits']);
    const h2buf = await subtle.deriveBits({name:'PBKDF2',hash:'SHA-256',iterations:14000,salt:enc.encode(_STATICRYPT_SALT)}, k2, 256);
    const h2 = hex(new Uint8Array(h2buf));

    // round 3 (SHA-256, 585000 it)
    msg.textContent='⏳ Cifratura in corso (questo richiede alcuni secondi)…';
    const k3 = await subtle.importKey('raw', enc.encode(h2), 'PBKDF2', false, ['deriveBits']);
    const h3buf = await subtle.deriveBits({name:'PBKDF2',hash:'SHA-256',iterations:585000,salt:enc.encode(_STATICRYPT_SALT)}, k3, 256);
    const h3 = hex(new Uint8Array(h3buf));

    // Importa chiave AES
    const rawKey = new Uint8Array(h3buf);
    const aesKey = await subtle.importKey('raw', rawKey, {name:'AES-CBC'}, false, ['encrypt']);

    // IV casuale
    const iv = crypto.getRandomValues(new Uint8Array(16));

    // Contenuto da cifrare: il sorgente della pagina decifrata
    const plainText = document.documentElement.outerHTML;
    const cipherBuf = await subtle.encrypt({name:'AES-CBC',iv}, aesKey, enc.encode(plainText));

    const ivHex = hex(iv);
    const cipherHex = hex(new Uint8Array(cipherBuf));
    const msgToSign = ivHex + cipherHex;

    // HMAC-SHA-256
    const hmacKey = await subtle.importKey('raw', enc.encode(h3), {name:'HMAC',hash:'SHA-256'}, false, ['sign']);
    const hmacBuf = await subtle.sign('HMAC', hmacKey, enc.encode(msgToSign));
    const hmacHex = hex(new Uint8Array(hmacBuf));

    const blob_final = hmacHex + msgToSign;

    // Ricostruisci index.html dal template
    const decoder = new TextDecoder();
    const templateBytes = Uint8Array.from(atob(_STATICRYPT_TEMPLATE_B64), c => c.charCodeAt(0));
    let newHtml = decoder.decode(templateBytes);
    newHtml = newHtml.replace('"staticryptEncryptedMsgUniqueVariableName":"__BLOB__"',
                              `"staticryptEncryptedMsgUniqueVariableName":"${blob_final}"`);
    newHtml = newHtml.replace('"staticryptSaltUniqueVariableName":"__SALT__"',
                              `"staticryptSaltUniqueVariableName":"${_STATICRYPT_SALT}"`);

    // Download
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([newHtml], {type:'text/html'}));
    a.download = 'index.html';
    a.click();

    msg.style.color='#178a5a';
    msg.textContent='✅ Nuovo index.html scaricato! Sostituisci il file nella cartella AFFITTI.';
    document.getElementById('cp-new').value='';
    document.getElementById('cp-confirm').value='';

  } catch(e) {
    msg.style.color='#c0392b';
    msg.textContent='❌ Errore durante la cifratura: ' + e.message;
    console.error(e);
  }
}

</script>

